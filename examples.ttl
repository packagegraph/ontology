# Example Package Instances
# Demonstrating how to represent real packages using the ontologies

@prefix ex:    <https://packagegraph.github.io/ontology/examples#> .
@prefix pkg:   <https://packagegraph.github.io/ontology/core#> .
@prefix deb:   <https://packagegraph.github.io/ontology/debian#> .
@prefix rpm:   <https://packagegraph.github.io/ontology/rpm#> .
@prefix arch:  <https://packagegraph.github.io/ontology/archlinux#> .
@prefix bsd:   <https://packagegraph.github.io/ontology/bsd#> .
@prefix choco: <https://packagegraph.github.io/ontology/chocolatey#> .
@prefix brew:  <https://packagegraph.github.io/ontology/homebrew#> .
@prefix nix:   <https://packagegraph.github.io/ontology/nix#> .
@prefix doap:  <http://usefulinc.com/ns/doap#> .
@prefix dct:   <http://purl.org/dc/terms/> .
@prefix dc:    <http://purl.org/dc/elements/1.1/> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix foaf:  <http://xmlns.com/foaf/0.1/> .
@prefix spdx:  <http://spdx.org/rdf/terms#> .
@prefix spdxl: <http://spdx.org/licenses/> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix sec:   <https://packagegraph.github.io/ontology/security#> .
@prefix met:   <https://packagegraph.github.io/ontology/metrics#> .
@prefix rh:    <https://packagegraph.github.io/ontology/redhat#> .

# Ontology metadata
<https://packagegraph.github.io/ontology/examples#> a owl:Ontology ;
  dc:title "PackageGraph Example Instances" ;
  dc:description "Example package instances demonstrating how to represent real packages using the PackageGraph ontologies across Debian, RPM, Arch Linux, BSD Ports, Chocolatey, Homebrew, and Nix." ;
  dct:abstract "Working examples showing how to instantiate PackageGraph classes for packages from each supported distribution. These examples use real package names and metadata to demonstrate cross-distribution interoperability, dependency modeling, VCS linking, and security vulnerability annotation." ;
  dct:license <https://creativecommons.org/publicdomain/zero/1.0/> ;
  owl:versionInfo "0.5.0" ;
  dct:created "2025-09-05"^^xsd:date ;
  dct:creator "Package Management Ontology Project" .

# License Individuals
spdxl:LGPL-2.1-only a spdx:ListedLicense ;
  rdfs:label "LGPL-2.1-only" .
spdxl:GPL-3.0-or-later a spdx:ListedLicense ;
  rdfs:label "GPL-3.0-or-later" .
spdxl:GPL-2.0-only a spdx:ListedLicense ;
  rdfs:label "GPL-2.0-only" .

# Example Maintainers (real maintainer data for demonstration)
ex:maintainer-doko a pkg:Maintainer ;
  rdfs:label "Matthias Klose" ;
  foaf:name "Matthias Klose" ;
  foaf:mbox <mailto:doko@debian.org> .

ex:maintainer-git a pkg:Maintainer ;
  rdfs:label "Jonathan Nieder" ;
  foaf:name "Jonathan Nieder" ;
  foaf:mbox <mailto:jrnieder@gmail.com> .

ex:maintainer-fedora a pkg:Maintainer ;
  rdfs:label "Fedora Release Engineering" ;
  foaf:name "Fedora Release Engineering" ;
  foaf:mbox <mailto:releng@fedoraproject.org> .

################################################################
# Debian (3)
################################################################

# glibc (Debian packaging repo on Salsa; upstream on Sourceware)
ex:glibc-deb a pkg:BinaryPackage, deb:BinaryPackage ;
  pkg:packageName "libc6" ;
  pkg:hasVersion ex:glibc-deb-version ;
  pkg:description "GNU C Library (Debian binary package: libc6)" ;
  pkg:homepage <https://sourceware.org/glibc/sources.html> ;
  pkg:downloadURL <https://salsa.debian.org/glibc-team/glibc> ;
  pkg:maintainedBy ex:glibc-deb-maintainer ;
  pkg:hasLicense spdxl:LGPL-2.1-only ;
  rdfs:label "GNU C Library (Debian binary package: libc6)" ;
  doap:repository [ a doap:GitRepository ;
    doap:location <https://sourceware.org/git/glibc.git> ;
    doap:browse   <https://sourceware.org/glibc/sources.html>
  ] .

ex:glibc-deb-version a pkg:Version ;
  rdfs:label "Version 2.31-13+deb11u3 for glibc-deb" ;
  pkg:versionString "2.31-13+deb11u3" .

ex:glibc-deb-maintainer a pkg:Maintainer ;
  rdfs:label "GNU C Library Debian Maintainers" ;
  foaf:name "GNU C Library Debian Maintainers" ;
  foaf:mbox <mailto:debian-glibc@lists.debian.org> .

# wget (Debian packaging on Salsa)
ex:wget-deb a pkg:BinaryPackage, deb:BinaryPackage ;
  pkg:packageName "wget" ;
  pkg:hasVersion ex:wget-deb-version ;
  pkg:description "Internet file retriever - Debian binary package" ;
  pkg:downloadURL <https://salsa.debian.org/debian/wget> ;
  pkg:maintainedBy ex:wget-deb-maintainer ;
  pkg:hasLicense spdxl:GPL-3.0-or-later ;
  rdfs:label "GNU Wget (Debian binary package)" .

ex:wget-deb-version a pkg:Version ;
    rdfs:label "Version 1.21.1-1+deb11u1 for wget-deb" ;
    pkg:versionString "1.21.1-1+deb11u1" .

ex:wget-deb-maintainer a pkg:Maintainer ;
    rdfs:label "Noel Torres" ;
    foaf:name "Noel Torres" ;
    foaf:mbox <mailto:ntorres@debian.org> .

# git (Debian packaging on Salsa)
ex:git-deb a pkg:BinaryPackage, deb:BinaryPackage ;
  pkg:packageName "git" ;
  pkg:hasVersion ex:git-deb-version ;
  pkg:description "Fast, scalable, distributed revision control system - Debian binary package" ;
  pkg:downloadURL <https://salsa.debian.org/debian/git> ;
  pkg:maintainedBy ex:maintainer-fedora ;
  pkg:hasLicense spdxl:GPL-2.0-only ;
  rdfs:label "Git version control (Debian binary package)" .

ex:git-deb-version a pkg:Version ;
    rdfs:label "Version 1:2.30.2-1 for git-deb" ;
    pkg:versionString "1:2.30.2-1" .

