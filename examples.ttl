################################################################
# Security (CVE and Advisory examples)
################################################################

# A critical vulnerability affecting glibc
ex:cve-2024-1234 a sec:Vulnerability ;
  sec:cveId "CVE-2024-1234" ;
  sec:cvssScore "9.8"^^xsd:float ;
  sec:severity "critical" ;
  sec:summary "Buffer overflow in glibc iconv module allows remote code execution" ;
  sec:cweId "CWE-119" ;
  sec:publishedDate "2024-03-15T00:00:00"^^xsd:dateTime ;
  sec:accessVector "network" ;
  sec:accessComplexity "low" ;
  sec:impactConfidentiality "high" ;
  sec:impactIntegrity "high" ;
  sec:impactAvailability "high" ;
  sec:exploitabilityScore "3.9"^^xsd:float ;
  sec:impactScore "5.9"^^xsd:float ;
  sec:affectsVersion ex:glibc-rpm-version ;
  rdfs:label "CVE-2024-1234" .

# Advisory addressing the vulnerability
ex:rhsa-2024-5678 a sec:SecurityAdvisory ;
  sec:advisoryId "RHSA-2024:5678" ;
  sec:advisorySeverity "critical" ;
  sec:advisoryDate "2024-03-20T00:00:00"^^xsd:dateTime ;
  sec:advisoryType "security" ;
  sec:addressesVulnerability ex:cve-2024-1234 ;
  sec:advisoryForPackage ex:glibc-rpm ;
  rdfs:label "RHSA-2024:5678" .

################################################################
# Code Metrics and Language examples
################################################################

# glibc is implemented in C and Assembly
ex:glibc-rpm met:implementedIn met:C, met:Assembly .

# Code metrics for the glibc RPM version
ex:glibc-rpm-version met:hasCodeMetrics ex:glibc-rpm-version-metrics .

ex:glibc-rpm-version-metrics a met:CodeMetrics ;
  met:totalLinesOfCode 1500000 ;
  met:totalFiles 4200 ;
  met:totalBlankLines 180000 ;
  met:totalCommentLines 250000 ;
  met:analysisDate "2024-06-01T00:00:00"^^xsd:dateTime ;
  met:hasLanguageMetrics ex:glibc-rpm-c-metrics, ex:glibc-rpm-asm-metrics ;
  rdfs:label "Code metrics for glibc 2.34-28.fc35" .

ex:glibc-rpm-c-metrics a met:LanguageMetrics ;
  met:language met:C ;
  met:linesOfCode 1200000 ;
  met:filesCount 3400 ;
  met:blankLines 140000 ;
  met:commentLines 200000 ;
  met:cyclomaticComplexity "15.2"^^xsd:float ;
  met:languageProportion "0.80"^^xsd:float ;
  rdfs:label "C language metrics for glibc" .

ex:glibc-rpm-asm-metrics a met:LanguageMetrics ;
  met:language met:Assembly ;
  met:linesOfCode 250000 ;
  met:filesCount 600 ;
  met:blankLines 30000 ;
  met:commentLines 40000 ;
  met:cyclomaticComplexity "8.5"^^xsd:float ;
  met:languageProportion "0.17"^^xsd:float ;
  rdfs:label "Assembly language metrics for glibc" .

################################################################
# Package Set and Vendor Extension examples
################################################################

# glibc is in RHEL BaseOS and is NOT vendor-originated (community project)
ex:glibc-rpm pkg:memberOfPackageSet rh:RHELBaseOS ;
  pkg:isVendorOriginated false .

ex:insights-client-rpm-version a pkg:Version ;
    rdfs:label "Version 3.1.0-1.el8 for insights-client-rpm" ;
    pkg:versionString "3.1.0-1.el8" .

# insights-client IS vendor-originated (Red Hat project)
ex:insights-client-srpm a rpm:SourceRPM, pkg:SourcePackage ;
  pkg:packageName "insights-client" ;
  pkg:hasVersion ex:insights-client-rpm-version ;
  rdfs:label "Red Hat Insights Client (source RPM)" .

ex:insights-client-rpm a pkg:BinaryPackage, rpm:BinaryRPM ;
  pkg:packageName "insights-client" ;
  pkg:builtFromSource ex:insights-client-srpm ;
  pkg:hasVersion ex:insights-client-rpm-version ;

  pkg:description "Red Hat Insights client for system analysis and recommendations" ;
  pkg:maintainedBy ex:maintainer-fedora ;
  pkg:hasLicense spdxl:GPL-2.0-only ;
  pkg:isVendorOriginated true ;
  pkg:memberOfPackageSet rh:RHELBaseOS ;
  rdfs:label "Red Hat Insights Client (RPM package)" .

ex:insights-client-version a pkg:Version ;
  rdfs:label "Version 3.2.0-1.el9 for insights-client" ;
  pkg:versionString "3.2.0-1.el9" .

################################################################
# Patch examples (SRPM with distro patches)
################################################################

ex:glibc-srpm a rpm:SourceRPM, pkg:SourcePackage ;
  pkg:packageName "glibc" ;
  pkg:hasVersion ex:glibc-rpm-version ;
  pkg:maintainedBy ex:maintainer-fedora ;
  pkg:hasLicense spdxl:LGPL-2.1-only ;
  rpm:patchCount 45 ;
  rpm:hasPatch ex:glibc-patch-1, ex:glibc-patch-2 ;
  rdfs:label "glibc source RPM" .

ex:glibc-patch-1 a rpm:Patch ;
  rpm:patchName "glibc-rh-2139875.patch" ;
  rpm:patchDescription "Fix memory corruption in iconv module for Red Hat specific locale handling" ;
  rpm:upstreamStatus "vendorSpecific" ;
  rdfs:label "glibc-rh-2139875.patch" .

ex:glibc-patch-2 a rpm:Patch ;
  rpm:patchName "glibc-upstream-backport-malloc.patch" ;
  rpm:patchDescription "Backport malloc performance improvement from glibc 2.36" ;
  rpm:upstreamStatus "backport" ;
  rdfs:label "glibc-upstream-backport-malloc.patch" .

################################################################
# PROV-O Provenance Chain Example
# Traces: upstream commit -> source package -> build -> binary
################################################################

# Upstream VCS commit
ex:openssl-commit-abc123 a vcs:Commit ;
  vcs:commitHash "abc123def456789" ;
  vcs:commitMessage "Release OpenSSL 3.2.1" ;
  vcs:commitTimestamp "2024-01-30T12:00:00Z"^^xsd:dateTime ;
  vcs:authoredBy ex:openssl-contributor ;
  rdfs:label "OpenSSL 3.2.1 release commit" .

ex:openssl-contributor a pkg:Contributor ;
  foaf:name "OpenSSL Release Team" ;
  rdfs:label "OpenSSL Release Team" .

# VCS tag (derived from commit via prov:wasDerivedFrom through parentCommit pattern)
ex:openssl-tag-3.2.1 a vcs:Release ;
  vcs:tagName "openssl-3.2.1" ;
  vcs:releaseDate "2024-01-30T14:00:00Z"^^xsd:dateTime ;
  vcs:pointsTo ex:openssl-commit-abc123 ;
  vcs:releasedBy ex:openssl-contributor ;
  rdfs:label "OpenSSL 3.2.1 release" .

# Source package derived from VCS tag
ex:openssl-deb-src a deb:SourcePackage, pkg:SourcePackage ;
  pkg:packageName "openssl" ;
  pkg:hasVersion ex:openssl-deb-src-version ;
  pkg:maintainedBy ex:maintainer-doko ;
  pkg:hasLicense spdxl:Apache-2.0 ;
  vcs:packagedFromTag ex:openssl-tag-3.2.1 ;
  rdfs:label "openssl Debian source package" .

ex:openssl-deb-src-version a pkg:Version ;
  pkg:versionString "3.2.1-1" ;
  rdfs:label "Version 3.2.1-1 for openssl" .

# Build activity with PROV-O linkage
ex:openssl-build-activity a pkg:BuildActivity ;
  pkg:performedBy ex:debian-buildd ;
  pkg:usedSource ex:openssl-deb-src ;
  pkg:activityStartTime "2024-02-01T10:00:00Z"^^xsd:dateTime ;
  pkg:activityEndTime "2024-02-01T10:45:00Z"^^xsd:dateTime ;
  pkg:exitCode 0 ;
  rdfs:label "openssl build on Debian buildd" .

ex:debian-buildd a slsa:Builder ;
  slsa:builderId "https://buildd.debian.org"^^xsd:anyURI ;
  slsa:builderVersion "wanna-build 2024.01" ;
  rdfs:label "Debian buildd" .

# Binary package produced by the build (full PROV-O chain)
ex:libssl3-deb a deb:BinaryPackage, pkg:BinaryPackage ;
  pkg:packageName "libssl3" ;
  pkg:hasVersion ex:libssl3-deb-version ;
  pkg:maintainedBy ex:maintainer-doko ;
  pkg:hasLicense spdxl:Apache-2.0 ;
  pkg:builtFromSource ex:openssl-deb-src ;
  pkg:wasBuiltBy ex:openssl-build-activity ;
  rdfs:label "libssl3 Debian binary package" .

ex:libssl3-deb-version a pkg:Version ;
  pkg:versionString "3.2.1-1" ;
  rdfs:label "Version 3.2.1-1 for libssl3" .

spdxl:Apache-2.0 a spdx:ListedLicense ;
  rdfs:label "Apache-2.0" .

################################################################
# SLSA Provenance Attestation Example
################################################################

# SLSA L2 attestation for a Koji-built RPM
ex:openssl-koji-provenance a slsa:ProvenanceAttestation ;
  slsa:attestsBuildLevel slsa:L2 ;
  slsa:attestationTimestamp "2024-02-01T11:30:00Z"^^xsd:dateTime ;
  slsa:attestationDigest "sha256:e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855" ;
  slsa:predicateType <https://slsa.dev/provenance/v1> ;
  slsa:verificationStatus "verified" ;
  slsa:attestsBuildActivity ex:openssl-koji-build ;
  slsa:hasSourceAttestation ex:openssl-koji-source-att ;
  rdfs:label "SLSA L2 provenance for openssl RPM" .

ex:openssl-koji-build a pkg:BuildActivity ;
  pkg:performedBy ex:koji-builder ;
  pkg:activityStartTime "2024-02-01T11:00:00Z"^^xsd:dateTime ;
  pkg:activityEndTime "2024-02-01T11:25:00Z"^^xsd:dateTime ;
  pkg:exitCode 0 ;
  slsa:builtBy ex:koji-builder ;
  slsa:usedBuildEnvironment ex:koji-build-env ;
  rdfs:label "openssl Koji build" .

ex:koji-builder a slsa:Builder ;
  slsa:builderId "https://koji.fedoraproject.org"^^xsd:anyURI ;
  slsa:builderVersion "1.34.0" ;
  rdfs:label "Fedora Koji" .

ex:koji-build-env a slsa:BuildEnvironment ;
  slsa:buildImage "fedora:39" ;
  slsa:isEphemeral true ;
  slsa:isIsolated true ;
  rdfs:label "Koji mock chroot (Fedora 39)" .

ex:openssl-koji-source-att a slsa:SourceAttestation ;
  slsa:sourceRepository <https://src.fedoraproject.org/rpms/openssl> ;
  slsa:sourceRef "f39" ;
  slsa:sourceDigest "sha256:deadbeef" ;
  slsa:twoPartyReviewed true ;
  slsa:hasSourceVcsRepository ex:fedora-openssl-repo ;
  rdfs:label "Source attestation for openssl Fedora RPM" .

ex:fedora-openssl-repo a vcs:Repository ;
  vcs:cloneUrl <https://src.fedoraproject.org/rpms/openssl.git> ;
  vcs:defaultBranch "rawhide" ;
  rdfs:label "Fedora openssl dist-git" .

# RPM with SLSA provenance link
ex:openssl-rpm a rpm:BinaryRPM, pkg:BinaryPackage ;
  pkg:packageName "openssl" ;
  pkg:hasVersion ex:openssl-rpm-version ;
  pkg:maintainedBy ex:maintainer-fedora ;
  pkg:hasLicense spdxl:Apache-2.0 ;
  pkg:builtFromSource ex:openssl-fedora-srpm ;
  pkg:wasBuiltBy ex:openssl-koji-build ;
  slsa:hasProvenance ex:openssl-koji-provenance ;
  rdfs:label "openssl Fedora RPM" .

ex:openssl-rpm-version a pkg:Version ;
  pkg:versionString "3.2.1-1.fc39" ;
  rdfs:label "Version 3.2.1-1.fc39 for openssl" .

ex:openssl-fedora-srpm a rpm:SourceRPM, pkg:SourcePackage ;
  pkg:packageName "openssl" ;
  pkg:hasVersion ex:openssl-rpm-version ;
  pkg:maintainedBy ex:maintainer-fedora ;
  pkg:hasLicense spdxl:Apache-2.0 ;
  rdfs:label "openssl Fedora source RPM" .

################################################################
# Security Patch Provenance Example
# Shows: unpatched version -> patch activity -> patched version
################################################################

ex:glibc-version-2.28-225 a pkg:Version ;
  pkg:versionString "2.28-225.el8" ;
  rdfs:label "glibc 2.28-225.el8 (unpatched)" .

ex:glibc-version-2.28-236 a pkg:Version ;
  pkg:versionString "2.28-236.el8_9.13" ;
  sec:patchedFrom ex:glibc-version-2.28-225 ;
  sec:patchProducedVersion ex:glibc-patch-activity ;
  rdfs:label "glibc 2.28-236.el8_9.13 (security patched)" .

ex:glibc-patch-activity a sec:PatchActivity ;
  pkg:performedBy ex:rhel-errata-team ;
  pkg:activityStartTime "2024-03-19T00:00:00Z"^^xsd:dateTime ;
  pkg:activityEndTime "2024-03-20T00:00:00Z"^^xsd:dateTime ;
  sec:patchAddresses ex:cve-2024-1234 ;
  rdfs:label "RHSA-2024:5678 patch activity" .

ex:rhel-errata-team a pkg:Contributor ;
  foaf:name "Red Hat Product Security" ;
  rdfs:label "Red Hat Product Security" .

ex:cve-2024-1234 a sec:Vulnerability ;
  sec:cveId "CVE-2024-1234" ;
  sec:cvssScore "9.8"^^xsd:float ;
  sec:severity "critical" ;
  sec:summary "Buffer overflow in glibc iconv module" ;
  sec:publishedDate "2024-03-15T00:00:00Z"^^xsd:dateTime ;
  sec:affectsVersion ex:glibc-version-2.28-225 ;
  sec:fixedInVersion ex:glibc-version-2.28-236 ;
  sec:affectsPackage ex:glibc-rpm ;
  rdfs:label "CVE-2024-1234" .

# Advisory addressing the vulnerability (updated with PROV-O linkage)
ex:rhsa-2024-5678 a sec:SecurityAdvisory ;
  sec:advisoryId "RHSA-2024:5678" ;
  sec:advisorySeverity "critical" ;
  sec:advisoryDate "2024-03-20T00:00:00Z"^^xsd:dateTime ;
  sec:advisoryType "security" ;
  sec:addressesVulnerability ex:cve-2024-1234 ;
  sec:advisoryForPackage ex:glibc-rpm ;
  rdfs:label "RHSA-2024:5678" .

# ============================================================
# Inverse Property Examples (Task 1)
# Demonstrating the newly added inverse properties
# ============================================================

# 1. versionOf (inverse of hasVersion)
# From the existing assertion: ex:glibc-deb pkg:hasVersion ex:glibc-deb-version
# The inverse:
ex:glibc-deb-version pkg:versionOf ex:glibc-deb .

# 2. isDirectDependencyOf (inverse of directlyDependsOn)
# Create example: wget depends on libc6
ex:wget-deb pkg:directlyDependsOn ex:glibc-deb .
# The inverse:
ex:glibc-deb pkg:isDirectDependencyOf ex:wget-deb .

# 3. hasPackage (inverse of isVersionOf)
# Assuming there's a PackageIdentity for glibc
ex:glibc-identity a pkg:PackageIdentity ;
  pkg:packageName "glibc" ;
  rdfs:label "glibc Package Identity" .

ex:glibc-deb pkg:isVersionOf ex:glibc-identity .
# The inverse:
ex:glibc-identity pkg:hasPackage ex:glibc-deb .

# 4. maintains (inverse of maintainedBy)
# From the existing assertion: ex:glibc-deb pkg:maintainedBy ex:glibc-deb-maintainer
# The inverse:
ex:glibc-deb-maintainer pkg:maintains ex:glibc-deb .

# 5. vcs:hasPackage (inverse of pkg:upstreamRepository)
# Create example repository
ex:glibc-upstream-repo a vcs:Repository ;
  vcs:repositoryURL "https://sourceware.org/git/glibc.git" ;
  rdfs:label "GNU C Library upstream repository" .

ex:glibc-identity pkg:upstreamRepository ex:glibc-upstream-repo .
# The inverse:
ex:glibc-upstream-repo vcs:hasPackage ex:glibc-identity .

# 6. sec:vulnerableIn (inverse of sec:affectsVersion)
# From the existing assertion: ex:cve-2024-1234 sec:affectsVersion ex:glibc-version-2.28-225
# The inverse:
ex:glibc-version-2.28-225 sec:vulnerableIn ex:cve-2024-1234 .

# ============================================================
# Capability Examples (Task 2)
# Demonstrating shared library dependency resolution
# ============================================================

# Capability: libssl.so.3 (shared library provided by openssl)
ex:cap-libssl-so-3 a pkg:Capability ;
  pkg:capabilityName "libssl.so.3" ;
  rdfs:label "OpenSSL shared library libssl.so.3" ;
  rdfs:comment "Shared library for SSL/TLS cryptography" .

# Capability: libc.so.6 (provided by glibc)
ex:cap-libc-so-6 a pkg:Capability ;
  pkg:capabilityName "libc.so.6(GLIBC_2.34)(64bit)" ;
  rdfs:label "GNU C Library shared library libc.so.6" ;
  rdfs:comment "Standard C library" .

# Source package for openssl
ex:openssl-source-deb a pkg:SourcePackage ;
  pkg:packageName "openssl" ;
  pkg:hasVersion ex:openssl-version ;
  rdfs:label "OpenSSL (Debian source package)" .

# Binary package that provides libssl.so.3
ex:openssl-deb a pkg:BinaryPackage, deb:DebianPackage ;
  pkg:packageName "openssl" ;
  pkg:hasVersion ex:openssl-version ;
  pkg:builtFromSource ex:openssl-source-deb ;
  pkg:providesCapability ex:cap-libssl-so-3 ;
  pkg:description "OpenSSL library package" ;
  rdfs:label "OpenSSL (Debian binary package)" .

ex:openssl-version a pkg:Version ;
  pkg:versionString "3.0.2-1" ;
  rdfs:label "OpenSSL version 3.0.2-1" .

# wget requires both capabilities
ex:wget-deb pkg:requiresCapability ex:cap-libssl-so-3, ex:cap-libc-so-6 ;
  rdfs:comment "Updated to show capability dependencies" .

# glibc provides libc.so.6
ex:glibc-deb pkg:providesCapability ex:cap-libc-so-6 .

# CVE blast radius via .so linking
# If libssl.so.3 has a vulnerability, all packages requiring it are affected
# Query: SELECT ?pkg WHERE { ?pkg pkg:requiresCapability ex:cap-libssl-so-3 }
# Result: ex:wget-deb (and any other packages requiring libssl.so.3)

# ============================================================
# Cross-Ecosystem Identity Linking (Task 3)
# Demonstrating Debian → PyPI → GitHub traversal
# ============================================================

# Upstream project: Requests (HTTP library)
ex:requests-project a pkg:UpstreamProject ;
  pkg:projectName "requests" ;
  pkg:projectRepository ex:requests-github-repo ;
  pkg:ecosystemPackage ex:requests-pypi-identity, ex:requests-debian-identity ;
  rdfs:label "Requests upstream project" ;
  rdfs:comment "HTTP library for humans" .

# GitHub repository
ex:requests-github-repo a vcs:Repository ;
  vcs:repositoryURL "https://github.com/psf/requests.git" ;
  rdfs:label "Requests GitHub repository" .

# PyPI package identity
ex:requests-pypi-identity a pkg:PackageIdentity ;
  pkg:packageName "requests" ;
  pkg:upstreamRepository ex:requests-github-repo ;
  pkg:upstreamEquivalent ex:requests-debian-identity ;
  rdfs:label "requests (PyPI)" ;
  rdfs:comment "PyPI package identity" .

# Debian package identity
ex:requests-debian-identity a pkg:PackageIdentity ;
  pkg:packageName "python3-requests" ;
  pkg:upstreamRepository ex:requests-github-repo ;
  pkg:upstreamPackageIdentity ex:requests-pypi-identity ;
  pkg:upstreamEquivalent ex:requests-pypi-identity ;
  rdfs:label "python3-requests (Debian)" ;
  rdfs:comment "Debian package identity" .

# Traversal demonstration:
# 1. Debian → PyPI: ex:requests-debian-identity pkg:upstreamPackageIdentity ex:requests-pypi-identity
# 2. Bidirectional: ex:requests-debian-identity pkg:upstreamEquivalent ex:requests-pypi-identity
# 3. Both → GitHub: both have pkg:upstreamRepository pointing to ex:requests-github-repo
# 4. Via UpstreamProject hub: ex:requests-project pkg:ecosystemPackage links both identities

# ============================================================
# External Identifiers (Task 4)
# Demonstrating PURL and CPE identifiers
# ============================================================

# Add PURL to existing package identities
ex:requests-pypi-identity pkg:purl "pkg:pypi/requests@2.28.2"^^xsd:anyURI .

ex:requests-debian-identity pkg:purl "pkg:deb/debian/python3-requests@2.28.2"^^xsd:anyURI ;
  sec:cpeId "cpe:2.3:a:python-requests:requests:2.28.2:*:*:*:*:*:*:*" .

# OpenSSL package identity with CPE
ex:openssl-identity a pkg:PackageIdentity ;
  pkg:packageName "openssl" ;
  pkg:purl "pkg:deb/debian/openssl@3.0.2"^^xsd:anyURI ;
  sec:cpeId "cpe:2.3:a:openssl:openssl:3.0.2:*:*:*:*:*:*:*" ;
  rdfs:label "OpenSSL package identity" .

# Link existing openssl-deb to its identity
ex:openssl-deb pkg:isVersionOf ex:openssl-identity .
ex:openssl-identity pkg:hasPackage ex:openssl-deb .