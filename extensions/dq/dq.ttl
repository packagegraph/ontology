# Data Quality Ontology
@prefix dq: <https://purl.org/packagegraph/ontology/dq#> .
@prefix pkg: <https://purl.org/packagegraph/ontology/core#> .
@prefix vcs: <https://purl.org/packagegraph/ontology/vcs#> .

@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix IAO: <http://purl.obolibrary.org/obo/IAO_> .


# Ontology Declaration
<https://purl.org/packagegraph/ontology/dq#> a owl:Ontology ;
    rdfs:label "Data Quality Ontology" ;
    rdfs:comment "Ontology for recording and querying data quality issues in the PackageGraph knowledge graph" ;
    dcterms:abstract """The Data Quality (DQ) ontology provides a structured way to record
        data quality issues discovered during ETL collection and enrichment.
        Issues are stored as first-class triples linked to the affected resources,
        making them queryable via SPARQL alongside the data they describe.

        This enables workflows such as:
        - Finding packages with dead upstream repositories
        - Identifying malformed maintainer emails in commit metadata
        - Tracking invalid homepage URLs across distributions
        - Monitoring data quality trends over time""" ;
    dcterms:created "2026-04-14"^^xsd:date ;
    dcterms:creator "PackageGraph Project" ;
    dcterms:title "Data Quality Ontology" ;
    dcterms:license <https://creativecommons.org/publicdomain/zero/1.0/> ;
    owl:versionInfo "0.1.0" ;
    owl:imports <https://purl.org/packagegraph/ontology/core#> .


# ─── Classes ─────────────────────────────────────────────────────────────────

dq:DataQualityIssue a owl:Class ;
    rdfs:label "Data Quality Issue" ;
    rdfs:comment "A recorded data quality issue found during collection or enrichment" ;
    IAO:0000115 """A structured record of a data quality problem discovered during
        ETL processing. Each issue is linked to the affected resource via
        dq:hasQualityIssue, enabling SPARQL queries to find packages,
        repositories, or other resources with specific quality problems.""" .


# ─── Issue Type Taxonomy ─────────────────────────────────────────────────────
#
# Known issue types (used as string values of dq:issueType):
#
#   dead-repo          Repository returned HTTP 404 (deleted, private, or moved)
#   malformed-email    Commit author email contains spaces, obfuscation, or garbage
#   invalid-homepage   Package homepage is not a valid HTTP(S) URL
#   missing-field      Required field is absent or empty
#   stale-data         Cached data exceeds expected freshness threshold
#   encoding-error     Field contains invalid characters or encoding


# ─── Properties ──────────────────────────────────────────────────────────────

dq:hasQualityIssue a owl:ObjectProperty ;
    rdfs:label "has quality issue" ;
    rdfs:comment "Links any resource to a data quality issue affecting it" ;
    rdfs:range dq:DataQualityIssue ;
    IAO:0000115 """Associates a resource (package, repository, maintainer, etc.)
        with a data quality issue that was discovered about it. The linked
        DataQualityIssue provides details about the issue type, affected field,
        raw value, and which component detected it.""" .

dq:issueType a owl:DatatypeProperty, owl:FunctionalProperty ;
    rdfs:label "issue type" ;
    rdfs:comment "Category of the data quality issue" ;
    rdfs:domain dq:DataQualityIssue ;
    rdfs:range xsd:string ;
    IAO:0000115 """A machine-readable category string identifying the type of
        data quality issue, e.g., 'dead-repo', 'malformed-email',
        'invalid-homepage', 'missing-field'. Used for filtering and
        aggregating issues in SPARQL queries.""" .

dq:field a owl:DatatypeProperty, owl:FunctionalProperty ;
    rdfs:label "affected field" ;
    rdfs:comment "The data field or property where the issue was found" ;
    rdfs:domain dq:DataQualityIssue ;
    rdfs:range xsd:string ;
    IAO:0000115 """Identifies which data field or property contains the quality
        issue, e.g., 'commit.author.email', 'homepage', 'packageName'.
        Uses dot notation for nested fields.""" .

dq:rawValue a owl:DatatypeProperty, owl:FunctionalProperty ;
    rdfs:label "raw value" ;
    rdfs:comment "The actual problematic value that triggered the issue" ;
    rdfs:domain dq:DataQualityIssue ;
    rdfs:range xsd:string ;
    IAO:0000115 """The original raw value that was identified as problematic,
        preserved for debugging and analysis. Truncated to 500 characters
        for excessively long values.""" .

dq:detectedBy a owl:DatatypeProperty, owl:FunctionalProperty ;
    rdfs:label "detected by" ;
    rdfs:comment "The enricher, collector, or validator that found the issue" ;
    rdfs:domain dq:DataQualityIssue ;
    rdfs:range xsd:string ;
    IAO:0000115 """Identifies which ETL component discovered the data quality
        issue, e.g., 'enrich-github-vcs', 'collect-debian',
        'validate-data'. Used to trace issues back to their detection
        source.""" .

dq:detectedAt a owl:DatatypeProperty ;
    rdfs:label "detected at" ;
    rdfs:comment "Timestamp when the issue was first detected" ;
    rdfs:domain dq:DataQualityIssue ;
    rdfs:range xsd:dateTime ;
    IAO:0000115 "The date and time when the data quality issue was first identified." .

dq:severity a owl:DatatypeProperty ;
    rdfs:label "severity" ;
    rdfs:comment "Severity level: info, warning, error" ;
    rdfs:domain dq:DataQualityIssue ;
    rdfs:range xsd:string ;
    IAO:0000115 """The severity level of the data quality issue:
        'info' for observations that may not require action,
        'warning' for issues that degrade data quality,
        'error' for issues that produce invalid or unusable data.""" .
