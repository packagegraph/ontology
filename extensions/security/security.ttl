# Security Ontology
@prefix sec: <https://purl.org/packagegraph/ontology/security#> .
@prefix pkg: <https://purl.org/packagegraph/ontology/core#> .

@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix IAO: <http://purl.obolibrary.org/obo/IAO_> .


# Ontology Declaration
<https://purl.org/packagegraph/ontology/security#> a owl:Ontology ;
    rdfs:label "Package Security Ontology" ;
    rdfs:comment "Ontology for representing security vulnerabilities, advisories, and their relationships to software packages" ;
    dcterms:abstract "The Security ontology models CVE vulnerabilities, vendor security advisories (RHSA, DSA, GLSA), and CVSS severity scores. It links vulnerabilities to affected and fixed package versions, enabling SPARQL queries such as finding all packages in a distribution affected by a given CVE, or listing unpatched vulnerabilities for a release." ;
    dcterms:created "2025-09-05"^^xsd:date ;
    dcterms:creator "PackageGraph Project" ;
    dcterms:title "Package Security Ontology" ;
    dcterms:description "A comprehensive ontology for modeling security vulnerabilities (CVEs), vendor security advisories (RHSA, DSA, GLSA), severity scoring, and their relationships to affected and fixed package versions." ;
    dcterms:license <https://creativecommons.org/publicdomain/zero/1.0/> ;
    owl:versionInfo "0.5.0" ;
    owl:imports <https://purl.org/packagegraph/ontology/core#> .


# #################################################################
# #
# #    Classes
# #
# #################################################################

sec:CVE a owl:Class ;
    rdfs:subClassOf owl:Thing ;
    rdfs:label "CVE Identifier" ;
    rdfs:comment "A Common Vulnerabilities and Exposures identifier entity, shared across vulnerability and advisory graphs" ;
    IAO:0000115 "A reified CVE identifier entity that can be shared across vulnerability records and advisories, enabling cross-graph CVE queries without string matching." .

sec:Vulnerability a owl:Class ;
    rdfs:subClassOf owl:Thing ;
    rdfs:label "Vulnerability" ;
    rdfs:comment "A known security vulnerability identified by a CVE record" ;
    IAO:0000115 "A known security vulnerability in software, identified and tracked using the Common Vulnerabilities and Exposures (CVE) system, including severity scoring and impact assessment." .

sec:SecurityAdvisory a owl:Class ;
    rdfs:subClassOf owl:Thing ;
    rdfs:label "Security Advisory" ;
    rdfs:comment "A vendor security advisory that addresses one or more vulnerabilities" ;
    IAO:0000115 "A vendor-issued security advisory (such as RHSA, DSA, or GLSA) that documents and addresses one or more known vulnerabilities, providing guidance and fixes for affected packages." .


# #################################################################
# #
# #    Data Properties — Vulnerability
# #
# #################################################################

sec:cveId a owl:DatatypeProperty, owl:FunctionalProperty ;
    rdfs:label "CVE identifier" ;
    rdfs:comment "The unique CVE identifier for the vulnerability" ;
    rdfs:domain sec:Vulnerability ;
    rdfs:range xsd:string ;
    IAO:0000115 "The unique Common Vulnerabilities and Exposures identifier." .

sec:cvssScore a owl:DatatypeProperty ;
    rdfs:label "CVSS score" ;
    rdfs:comment "The CVSS base score for the vulnerability" ;
    rdfs:domain sec:Vulnerability ;
    rdfs:range xsd:float ;
    IAO:0000115 "The Common Vulnerability Scoring System score (0.0-10.0)." .

sec:cvssVector a owl:DatatypeProperty ;
    rdfs:label "CVSS vector" ;
    rdfs:comment "The full CVSS vector string for the vulnerability" ;
    rdfs:domain sec:Vulnerability ;
    rdfs:range xsd:string ;
    IAO:0000115 "The full CVSS vector string encoding the vulnerability characteristics." .

sec:severity a owl:DatatypeProperty ;
    rdfs:label "severity" ;
    rdfs:comment "The severity level of the vulnerability" ;
    rdfs:domain sec:Vulnerability ;
    rdfs:range xsd:string ;
    IAO:0000115 "The severity classification: low, medium, high, or critical." .

sec:summary a owl:DatatypeProperty ;
    rdfs:label "summary" ;
    rdfs:comment "A human-readable summary of the vulnerability" ;
    rdfs:domain sec:Vulnerability ;
    rdfs:range xsd:string ;
    IAO:0000115 "A human-readable description of the vulnerability." .

sec:publishedDate a owl:DatatypeProperty ;
    rdfs:label "published date" ;
    rdfs:comment "The date the vulnerability was publicly disclosed" ;
    rdfs:domain sec:Vulnerability ;
    rdfs:range xsd:dateTime ;
    IAO:0000115 "The date when the vulnerability was publicly disclosed." .

sec:updatedDate a owl:DatatypeProperty ;
    rdfs:label "updated date" ;
    rdfs:comment "The date the vulnerability record was last modified" ;
    rdfs:domain sec:Vulnerability ;
    rdfs:range xsd:dateTime ;
    IAO:0000115 "The date when the vulnerability record was last modified." .

sec:cweId a owl:DatatypeProperty ;
    rdfs:label "CWE identifier" ;
    rdfs:comment "The CWE identifier classifying the vulnerability type" ;
    rdfs:domain sec:Vulnerability ;
    rdfs:range xsd:string ;
    IAO:0000115 "The Common Weakness Enumeration identifier classifying the vulnerability type." .

sec:cpeId a owl:DatatypeProperty ;
    rdfs:label "CPE identifier" ;
    rdfs:comment "Common Platform Enumeration identifier for the package" ;
    rdfs:domain pkg:PackageIdentity ;
    rdfs:range xsd:string ;
    IAO:0000115 "Common Platform Enumeration (CPE) 2.3 identifier linking this package to NVD vulnerability feeds. Format: cpe:2.3:a:vendor:product:version:*:*:*:*:*:*:*. Enables cross-referencing with CVE databases." .

sec:accessVector a owl:DatatypeProperty ;
    rdfs:label "access vector" ;
    rdfs:comment "The attack vector for the vulnerability" ;
    rdfs:domain sec:Vulnerability ;
    rdfs:range xsd:string ;
    IAO:0000115 "The attack vector: network, adjacent, local, or physical." .

sec:accessComplexity a owl:DatatypeProperty ;
    rdfs:label "access complexity" ;
    rdfs:comment "The complexity of the attack required to exploit the vulnerability" ;
    rdfs:domain sec:Vulnerability ;
    rdfs:range xsd:string ;
    IAO:0000115 "The complexity of the attack required to exploit the vulnerability." .

sec:impactConfidentiality a owl:DatatypeProperty ;
    rdfs:label "impact on confidentiality" ;
    rdfs:comment "The impact on confidentiality if the vulnerability is exploited" ;
    rdfs:domain sec:Vulnerability ;
    rdfs:range xsd:string ;
    IAO:0000115 "The impact on confidentiality: none, low, or high." .

sec:impactIntegrity a owl:DatatypeProperty ;
    rdfs:label "impact on integrity" ;
    rdfs:comment "The impact on data integrity if the vulnerability is exploited" ;
    rdfs:domain sec:Vulnerability ;
    rdfs:range xsd:string ;
    IAO:0000115 "The impact on data integrity: none, low, or high." .

sec:impactAvailability a owl:DatatypeProperty ;
    rdfs:label "impact on availability" ;
    rdfs:comment "The impact on system availability if the vulnerability is exploited" ;
    rdfs:domain sec:Vulnerability ;
    rdfs:range xsd:string ;
    IAO:0000115 "The impact on system availability: none, low, or high." .

sec:exploitabilityScore a owl:DatatypeProperty ;
    rdfs:label "exploitability score" ;
    rdfs:comment "The CVSS exploitability sub-score" ;
    rdfs:domain sec:Vulnerability ;
    rdfs:range xsd:float ;
    IAO:0000115 "The CVSS exploitability sub-score." .

sec:impactScore a owl:DatatypeProperty ;
    rdfs:label "impact score" ;
    rdfs:comment "The CVSS impact sub-score" ;
    rdfs:domain sec:Vulnerability ;
    rdfs:range xsd:float ;
    IAO:0000115 "The CVSS impact sub-score." .


# #################################################################
# #
# #    Data Properties — SecurityAdvisory
# #
# #################################################################

sec:advisoryId a owl:DatatypeProperty, owl:FunctionalProperty ;
    rdfs:label "advisory identifier" ;
    rdfs:comment "The unique identifier for the security advisory" ;
    rdfs:domain sec:SecurityAdvisory ;
    rdfs:range xsd:string ;
    IAO:0000115 "The unique identifier for the security advisory." .

sec:advisorySeverity a owl:DatatypeProperty ;
    rdfs:label "advisory severity" ;
    rdfs:comment "The overall severity level of the advisory" ;
    rdfs:domain sec:SecurityAdvisory ;
    rdfs:range xsd:string ;
    IAO:0000115 "The overall severity level assigned to the advisory." .

sec:advisoryDate a owl:DatatypeProperty ;
    rdfs:label "advisory date" ;
    rdfs:comment "The date the security advisory was published" ;
    rdfs:domain sec:SecurityAdvisory ;
    rdfs:range xsd:dateTime ;
    IAO:0000115 "The date when the security advisory was published." .

sec:advisoryType a owl:DatatypeProperty ;
    rdfs:label "advisory type" ;
    rdfs:comment "The type of advisory" ;
    rdfs:domain sec:SecurityAdvisory ;
    rdfs:range xsd:string ;
    IAO:0000115 "The type of advisory: security, bugfix, or enhancement." .


# #################################################################
# #
# #    Object Properties
# #
# #################################################################

sec:affectsVersion a owl:ObjectProperty ;
    owl:inverseOf sec:vulnerableIn ;
    rdfs:label "affects version" ;
    rdfs:comment "Links a vulnerability to the package versions it affects" ;
    rdfs:domain sec:Vulnerability ;
    rdfs:range pkg:Version ;
    IAO:0000115 "Associates a vulnerability with the package versions it affects." .

sec:vulnerableIn a owl:ObjectProperty ;
    rdfs:label "vulnerable in" ;
    rdfs:comment "Links a package version to the vulnerabilities that affect it" ;
    rdfs:domain pkg:Version ;
    rdfs:range sec:Vulnerability ;
    IAO:0000115 "The inverse relationship of affectsVersion, linking a package version to the vulnerabilities it is affected by. Enables efficient 'what CVEs affect this version' queries without scanning all vulnerabilities." .

sec:fixedInVersion a owl:ObjectProperty ;
    rdfs:label "fixed in version" ;
    rdfs:comment "Links a vulnerability to the package version containing its fix" ;
    rdfs:domain sec:Vulnerability ;
    rdfs:range pkg:Version ;
    IAO:0000115 "Associates a vulnerability with the package version that contains its fix." .

sec:addressesVulnerability a owl:ObjectProperty ;
    rdfs:label "addresses vulnerability" ;
    rdfs:comment "Links a security advisory to the vulnerabilities it addresses" ;
    rdfs:domain sec:SecurityAdvisory ;
    rdfs:range sec:Vulnerability ;
    IAO:0000115 "Links a security advisory to the vulnerabilities it addresses." .

sec:cveEntity a owl:ObjectProperty ;
    rdfs:label "CVE entity" ;
    rdfs:comment "Links a vulnerability or advisory to a shared CVE identifier entity" ;
    rdfs:range sec:CVE ;
    IAO:0000115 "Associates a vulnerability or advisory with a reified CVE identifier entity, enabling graph-traversable relationships across all records that reference the same CVE." .

sec:hasCWE a owl:ObjectProperty ;
    rdfs:label "has CWE" ;
    rdfs:comment "Links a vulnerability to a CWE weakness category entity" ;
    rdfs:domain sec:Vulnerability ;
    IAO:0000115 "Associates a vulnerability with a Common Weakness Enumeration category entity, enabling classification and analysis of vulnerability types." .

sec:advisoryForPackage a owl:ObjectProperty ;
    rdfs:label "advisory for package" ;
    rdfs:comment "Links a security advisory to the package it applies to" ;
    rdfs:domain sec:SecurityAdvisory ;
    rdfs:range pkg:Package ;
    IAO:0000115 "Associates a security advisory with the package it applies to." .


# #################################################################
# #
# #    Cardinality Restrictions
# #
# #################################################################

sec:Vulnerability rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty sec:cveId ;
    owl:cardinality 1
] .

sec:SecurityAdvisory rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty sec:advisoryId ;
    owl:cardinality 1
] .


# #################################################################
# #
# #    Supply Chain Security Classes
# #
# #################################################################

sec:PatchActivity a owl:Class ;
    rdfs:subClassOf pkg:PackagingActivity ;
    rdfs:label "Patch Activity" ;
    rdfs:comment "An activity that applies a security patch to produce a fixed package version" ;
    IAO:0000115 "A packaging activity that applies one or more security patches to address vulnerabilities, producing a new package version derived from the unpatched version." .


# #################################################################
# #
# #    Supply Chain Object Properties
# #
# #################################################################

sec:patchedFrom a owl:ObjectProperty ;
    rdfs:subPropertyOf prov:wasDerivedFrom ;
    rdfs:label "patched from" ;
    rdfs:comment "Links a patched package version to the unpatched version it was derived from" ;
    rdfs:domain pkg:Version ;
    rdfs:range pkg:Version ;
    IAO:0000115 "Associates a security-patched package version with the prior version from which it was derived, establishing the provenance chain for security updates." .

sec:patchAddresses a owl:ObjectProperty ;
    rdfs:label "patch addresses" ;
    rdfs:comment "Links a patch activity to the vulnerabilities it fixes" ;
    rdfs:domain sec:PatchActivity ;
    rdfs:range sec:Vulnerability ;
    IAO:0000115 "Associates a patch activity with the specific vulnerabilities that it addresses." .

sec:patchProducedVersion a owl:ObjectProperty ;
    rdfs:subPropertyOf prov:wasGeneratedBy ;
    rdfs:label "patch produced version" ;
    rdfs:comment "Links a fixed package version to the patch activity that produced it" ;
    rdfs:domain pkg:Version ;
    rdfs:range sec:PatchActivity ;
    IAO:0000115 "Associates a fixed package version with the patch activity that produced it from the prior version." .

sec:affectsPackage a owl:ObjectProperty ;
    owl:inverseOf sec:hasVulnerabilityReport ;
    rdfs:label "affects package" ;
    rdfs:comment "Links a vulnerability directly to an affected package identity" ;
    rdfs:domain sec:Vulnerability ;
    rdfs:range pkg:PackageIdentity ;
    IAO:0000115 "Associates a vulnerability directly with an affected package identity, bypassing version-string joins for direct package-level queries." .

sec:hasVulnerabilityReport a owl:ObjectProperty ;
    rdfs:label "has vulnerability report" ;
    rdfs:comment "Links a package identity to vulnerabilities that affect it" ;
    rdfs:domain pkg:PackageIdentity ;
    rdfs:range sec:Vulnerability ;
    IAO:0000115 "The inverse relationship of affectsPackage, linking a package identity to the vulnerabilities that affect it. Enables efficient 'what CVEs affect this package' queries." .
