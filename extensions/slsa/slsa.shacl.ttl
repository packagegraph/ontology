@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix slsa: <https://purl.org/packagegraph/ontology/slsa#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

slsa:BuildEnvironmentShape a sh:NodeShape ;
    sh:property [ sh:datatype xsd:boolean ;
            sh:maxCount 1 ;
            sh:message "A build environment can have at most one ephemeral flag."@en ;
            sh:path slsa:isEphemeral ],
        [ sh:datatype xsd:boolean ;
            sh:maxCount 1 ;
            sh:message "A build environment can have at most one isolated flag."@en ;
            sh:path slsa:isIsolated ] ;
    sh:targetClass slsa:BuildEnvironment .

slsa:BuildLevelShape a sh:NodeShape ;
    sh:property [ sh:message "A build level must have at least one label."@en ;
            sh:minCount 1 ;
            sh:path rdfs:label ] ;
    sh:targetClass slsa:BuildLevel .

slsa:BuilderShape a sh:NodeShape ;
    sh:property [ sh:datatype xsd:anyURI ;
            sh:maxCount 1 ;
            sh:message "A builder must have exactly one builder ID URI."@en ;
            sh:minCount 1 ;
            sh:path slsa:builderId ] ;
    sh:targetClass slsa:Builder .

slsa:ProvenanceAttestationShape a sh:NodeShape ;
    sh:property [ sh:class slsa:BuildLevel ;
            sh:maxCount 1 ;
            sh:message "A provenance attestation must attest exactly one SLSA build level."@en ;
            sh:minCount 1 ;
            sh:path slsa:attestsBuildLevel ],
        [ sh:datatype xsd:dateTime ;
            sh:maxCount 1 ;
            sh:message "A provenance attestation may have at most one timestamp."@en ;
            sh:path slsa:attestationTimestamp ],
        [ sh:datatype xsd:string ;
            sh:message "A provenance attestation must have at least one artifact digest."@en ;
            sh:minCount 1 ;
            sh:path slsa:attestationDigest ] ;
    sh:targetClass slsa:ProvenanceAttestation .

