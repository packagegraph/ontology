# Buildroot Build System Ontology
@prefix buildroot: <https://purl.org/packagegraph/ontology/buildroot#> .
@prefix pkg: <https://purl.org/packagegraph/ontology/core#> .
@prefix sec: <https://purl.org/packagegraph/ontology/security#> .

@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix IAO: <http://purl.obolibrary.org/obo/IAO_> .

<https://purl.org/packagegraph/ontology/buildroot#> a owl:Ontology ;
    rdfs:label "Buildroot Build System Ontology" ;
    rdfs:comment "Ontology for representing Buildroot packages and build configurations" ;
    dcterms:abstract "Models the Buildroot embedded Linux build system, including package definitions (.mk files), Kconfig-based configuration, download sites, install staging/target directives, and defconfig board configurations. Buildroot is optimized for minimal embedded Linux images with reproducible builds. Packages are defined via Makefile syntax with <PKGNAME>_ prefixed variables." ;
    dcterms:created "2026-04-17"^^xsd:date ;
    dcterms:license <https://creativecommons.org/publicdomain/zero/1.0/> ;
    owl:versionInfo "0.6.0" ;
    owl:imports <core.ttl> .

# =============================================================================
# Classes
# =============================================================================

buildroot:BuildrootPackage a owl:Class ;
    rdfs:subClassOf pkg:SourcePackage ;
    rdfs:label "Buildroot Package" ;
    rdfs:comment "A Buildroot package definition" ;
    IAO:0000115 "A package defined by a .mk file in Buildroot's package/ directory, using Makefile syntax with <PKGNAME>_ prefixed variables. Each package directory contains a .mk file (build logic), Config.in (Kconfig selection), and optionally hash files for source verification." .

buildroot:BuildInfrastructure a owl:Class ;
    rdfs:subClassOf owl:Thing ;
    rdfs:label "Build Infrastructure" ;
    rdfs:comment "A Buildroot package infrastructure defining the build system" ;
    IAO:0000115 "A package infrastructure defining build steps and macros. The infrastructure type (e.g., autotools-package, cmake-package, generic-package, python-package) determines what build variables are available and how the package is configured, compiled, and installed." .

buildroot:Defconfig a owl:Class ;
    rdfs:subClassOf prov:Entity ;
    rdfs:label "Defconfig" ;
    rdfs:comment "A Buildroot board defconfig (saved .config)" ;
    IAO:0000115 "A board-specific default configuration (defconfig) saved in configs/ directory. Defconfigs define the complete package selection, toolchain, and kernel configuration for a target board. They are the primary input to Buildroot — running 'make <board>_defconfig' selects all packages for that target." .

# =============================================================================
# Datatype Properties
# =============================================================================

buildroot:site a owl:DatatypeProperty ;
    rdfs:label "site" ;
    rdfs:domain buildroot:BuildrootPackage ;
    rdfs:range xsd:string ;
    IAO:0000115 "The download site URL from <PKG>_SITE variable (e.g., 'https://www.openssl.org/source/'). Identifies the upstream source origin for provenance analysis." .

buildroot:siteMethod a owl:DatatypeProperty ;
    rdfs:label "site method" ;
    rdfs:domain buildroot:BuildrootPackage ;
    rdfs:range xsd:string ;
    IAO:0000115 "The download method from <PKG>_SITE_METHOD variable (e.g., 'wget', 'git', 'svn', 'hg', 'local'). Reveals the source fetch protocol for provenance chain analysis." .

buildroot:installStaging a owl:DatatypeProperty ;
    rdfs:label "install staging" ;
    rdfs:domain buildroot:BuildrootPackage ;
    rdfs:range xsd:boolean ;
    IAO:0000115 "Whether the package installs to the staging directory (<PKG>_INSTALL_STAGING = YES), making headers and libraries available to other packages at build time. A proxy for 'this package provides a development API'." .

buildroot:installTarget a owl:DatatypeProperty ;
    rdfs:label "install target" ;
    rdfs:domain buildroot:BuildrootPackage ;
    rdfs:range xsd:boolean ;
    IAO:0000115 "Whether the package installs to the target filesystem (<PKG>_INSTALL_TARGET = YES), deploying binaries/libraries to the final image. Packages with installTarget=false are build-only tools." .

buildroot:source a owl:DatatypeProperty ;
    rdfs:label "source" ;
    rdfs:domain buildroot:BuildrootPackage ;
    rdfs:range xsd:string ;
    IAO:0000115 "The source archive filename from <PKG>_SOURCE variable (e.g., 'openssl-1.1.1.tar.gz')." .

buildroot:sourceHash a owl:DatatypeProperty ;
    rdfs:label "source hash" ;
    rdfs:domain buildroot:BuildrootPackage ;
    rdfs:range xsd:string ;
    IAO:0000115 "The expected hash of the source archive from the .hash file. Buildroot verifies downloads against this hash for reproducibility." .

buildroot:cpeId a owl:DatatypeProperty ;
    rdfs:label "CPE ID" ;
    rdfs:domain buildroot:BuildrootPackage ;
    rdfs:range xsd:string ;
    IAO:0000115 "The full CPE 2.3 identifier constructed from <PKG>_CPE_ID_VENDOR and <PKG>_CPE_ID_PRODUCT variables. Used for CVE matching against the NVD database. Critical for security analysis of embedded firmware." .

buildroot:cpeVendor a owl:DatatypeProperty ;
    rdfs:label "CPE vendor" ;
    rdfs:domain buildroot:BuildrootPackage ;
    rdfs:range xsd:string ;
    IAO:0000115 "The CPE vendor identifier from <PKG>_CPE_ID_VENDOR variable for CVE matching." .

buildroot:cpeProduct a owl:DatatypeProperty ;
    rdfs:label "CPE product" ;
    rdfs:domain buildroot:BuildrootPackage ;
    rdfs:range xsd:string ;
    IAO:0000115 "The CPE product identifier from <PKG>_CPE_ID_PRODUCT variable for CVE matching." .

buildroot:licenseFiles a owl:DatatypeProperty ;
    rdfs:label "license files" ;
    rdfs:domain buildroot:BuildrootPackage ;
    rdfs:range xsd:string ;
    IAO:0000115 "The license file paths from <PKG>_LICENSE_FILES variable (space-separated). Buildroot uses these to generate the legal-info manifest for license compliance." .

buildroot:redistributable a owl:DatatypeProperty ;
    rdfs:label "redistributable" ;
    rdfs:domain buildroot:BuildrootPackage ;
    rdfs:range xsd:boolean ;
    IAO:0000115 "Whether the package's license permits redistribution (<PKG>_REDISTRIBUTE = YES/NO). Buildroot excludes non-redistributable packages from the legal-info tarball." .

buildroot:configOpts a owl:DatatypeProperty ;
    rdfs:label "configuration options" ;
    rdfs:domain buildroot:BuildrootPackage ;
    rdfs:range xsd:string ;
    IAO:0000115 "Configuration options passed to ./configure from <PKG>_CONF_OPTS variable. Reveals which optional features are enabled/disabled in this build." .

buildroot:defconfigName a owl:DatatypeProperty ;
    rdfs:label "defconfig name" ;
    rdfs:domain buildroot:Defconfig ;
    rdfs:range xsd:string ;
    IAO:0000115 "The defconfig filename (e.g., 'raspberrypi4_defconfig', 'qemu_x86_64_defconfig')." .

buildroot:defconfigArch a owl:DatatypeProperty ;
    rdfs:label "defconfig architecture" ;
    rdfs:domain buildroot:Defconfig ;
    rdfs:range xsd:string ;
    IAO:0000115 "The target architecture of this defconfig (e.g., 'arm', 'aarch64', 'x86_64')." .

# =============================================================================
# Object Properties
# =============================================================================

buildroot:usesInfrastructure a owl:ObjectProperty ;
    rdfs:label "uses infrastructure" ;
    rdfs:domain buildroot:BuildrootPackage ;
    rdfs:range buildroot:BuildInfrastructure ;
    IAO:0000115 "Associates a package with the build infrastructure it uses. Reveals the upstream build system and available build hooks." .

buildroot:selectedByDefconfig a owl:ObjectProperty ;
    rdfs:label "selected by defconfig" ;
    rdfs:domain buildroot:BuildrootPackage ;
    rdfs:range buildroot:Defconfig ;
    IAO:0000115 "Associates a package with defconfigs that select it. Enables 'what packages are in this board image' queries." .

buildroot:matchesCVE a owl:ObjectProperty ;
    rdfs:label "matches CVE" ;
    rdfs:domain buildroot:BuildrootPackage ;
    rdfs:range sec:Vulnerability ;
    IAO:0000115 "Associates a Buildroot package with CVE vulnerabilities matched via its CPE identifier. Buildroot's pkg-stats tool performs this matching automatically." .

# =============================================================================
# Common Build Infrastructures (named individuals for SPARQL aggregation)
# =============================================================================

buildroot:autotoolsPackage a buildroot:BuildInfrastructure ;
    rdfs:label "autotools-package" ;
    rdfs:comment "GNU Autotools (./configure && make && make install)" .

buildroot:cmakePackage a buildroot:BuildInfrastructure ;
    rdfs:label "cmake-package" ;
    rdfs:comment "CMake build system" .

buildroot:mesonPackage a buildroot:BuildInfrastructure ;
    rdfs:label "meson-package" ;
    rdfs:comment "Meson build system" .

buildroot:genericPackage a buildroot:BuildInfrastructure ;
    rdfs:label "generic-package" ;
    rdfs:comment "Generic package with custom build steps" .

buildroot:pythonPackage a buildroot:BuildInfrastructure ;
    rdfs:label "python-package" ;
    rdfs:comment "Python setuptools/flit/poetry package" .

buildroot:goPackage a buildroot:BuildInfrastructure ;
    rdfs:label "golang-package" ;
    rdfs:comment "Go language package" .

buildroot:cargoPackage a buildroot:BuildInfrastructure ;
    rdfs:label "cargo-package" ;
    rdfs:comment "Rust/Cargo package" .

buildroot:kernelModule a buildroot:BuildInfrastructure ;
    rdfs:label "kernel-module" ;
    rdfs:comment "Out-of-tree Linux kernel module" .

buildroot:virtualPackage a buildroot:BuildInfrastructure ;
    rdfs:label "virtual-package" ;
    rdfs:comment "Virtual package providing an interface (e.g., virtual/libc)" .

buildroot:hostPackage a buildroot:BuildInfrastructure ;
    rdfs:label "host-package" ;
    rdfs:comment "Package built for the host (build machine) rather than the target" .
