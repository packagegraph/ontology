@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix pkg: <https://purl.org/packagegraph/ontology/core#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sec: <https://purl.org/packagegraph/ontology/security#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

pkg:BinaryPackageShape a sh:NodeShape ;
    sh:property [ sh:class pkg:SourcePackage ;
            sh:maxCount 1 ;
            sh:message "A binary package must be built from exactly one source package." ;
            sh:minCount 1 ;
            sh:path pkg:builtFromSource ] ;
    sh:targetClass pkg:BinaryPackage .

pkg:BuildActivityShape a sh:NodeShape ;
    sh:property [ sh:class prov:Agent ;
            sh:message "A build activity's performer must be a prov:Agent." ;
            sh:path pkg:performedBy ] ;
    sh:targetClass pkg:BuildActivity .

pkg:CapabilityShape a sh:NodeShape ;
    sh:property [ sh:datatype xsd:string ;
            sh:message "A capability must have at least one label." ;
            sh:minCount 1 ;
            sh:path rdfs:label ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:message "A capability must have exactly one capability name." ;
            sh:minCount 1 ;
            sh:path pkg:capabilityName ] ;
    sh:targetClass pkg:Capability .

pkg:ContributorAccountShape a sh:NodeShape ;
    sh:property [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:message "A contributor account must have exactly one platform." ;
            sh:minCount 1 ;
            sh:path pkg:accountPlatform ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:message "A contributor account must have exactly one username." ;
            sh:minCount 1 ;
            sh:path pkg:accountUsername ] ;
    sh:targetClass pkg:ContributorAccount .

pkg:DistributionReleaseShape a sh:NodeShape ;
    sh:property [ sh:datatype xsd:string ;
            sh:message "A distribution release must have at least one label." ;
            sh:minCount 1 ;
            sh:path rdfs:label ] ;
    sh:targetClass pkg:DistributionRelease .

pkg:InstalledFileShape a sh:NodeShape ;
    sh:property [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:message "An installed file must have exactly one file path." ;
            sh:minCount 1 ;
            sh:path pkg:installedFilePath ] ;
    sh:targetClass pkg:InstalledFile .

pkg:MaintainerShape a sh:NodeShape ;
    sh:property [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:message "A maintainer must have exactly one foaf:name." ;
            sh:minCount 1 ;
            sh:path foaf:name ] ;
    sh:targetClass pkg:Maintainer .

pkg:PURLShape a sh:NodeShape ;
    sh:property [ sh:datatype xsd:anyURI ;
            sh:maxCount 1 ;
            sh:message "A PURL must follow the format pkg:type/namespace/name@version" ;
            sh:path pkg:purl ;
            sh:pattern "^pkg:[a-z]+/.+@.+" ] ;
    sh:targetClass pkg:PackageIdentity .

pkg:PackageSetShape a sh:NodeShape ;
    sh:property [ sh:datatype xsd:string ;
            sh:message "A package set must have at least one label." ;
            sh:minCount 1 ;
            sh:path rdfs:label ] ;
    sh:targetClass pkg:PackageSet .

pkg:PackageShape a sh:NodeShape ;
    sh:property [ sh:message "A package must have at least one version." ;
            sh:minCount 1 ;
            sh:path pkg:hasVersion ],
        [ sh:maxCount 1 ;
            sh:message "A package must have exactly one package name." ;
            sh:path pkg:packageName ],
        [ sh:maxCount 1 ;
            sh:message "A package can have at most one homepage." ;
            sh:path pkg:homepage ],
        [ sh:maxCount 1 ;
            sh:message "A package can have at most one download URL." ;
            sh:path pkg:downloadURL ],
        [ sh:maxCount 1 ;
            sh:message "A package can have at most one checksum." ;
            sh:path pkg:checksum ],
        [ sh:class pkg:Maintainer ;
            sh:message "The value of pkg:maintainedBy must be a pkg:Maintainer." ;
            sh:path pkg:maintainedBy ] ;
    sh:targetClass pkg:Package .

pkg:SourcePackageShape a sh:NodeShape ;
    sh:targetClass pkg:SourcePackage .

pkg:UpstreamProjectShape a sh:NodeShape ;
    sh:property [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:message "An upstream project must have exactly one project name." ;
            sh:minCount 1 ;
            sh:path pkg:projectName ] ;
    sh:targetClass pkg:UpstreamProject .

pkg:VersionShape a sh:NodeShape ;
    sh:property [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:message "A version must have exactly one version string." ;
            sh:minCount 1 ;
            sh:path pkg:versionString ] ;
    sh:targetClass pkg:Version .

sec:CPEShape a sh:NodeShape ;
    sh:property [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:message "A CPE identifier must follow CPE 2.3 format: cpe:2.3:part:vendor:product:version:update:edition:language:sw_edition:target_sw:target_hw:other" ;
            sh:path sec:cpeId ;
            sh:pattern "^cpe:2\\.3:[aho]:[^:]+:[^:]+:[^:]+:[^:]*:[^:]*:[^:]*:[^:]*:[^:]*:[^:]*:[^:]*$" ] ;
    sh:targetClass pkg:PackageIdentity .

