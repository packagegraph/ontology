@prefix nix: <https://purl.org/packagegraph/ontology/nix#> .
@prefix pkg: <https://purl.org/packagegraph/ontology/core#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

nix:NixPackageShape a sh:NodeShape ;
    sh:property [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:message "A Nix package must have exactly one package name."@en ;
            sh:minCount 1 ;
            sh:path pkg:packageName ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:message "A Nix package must have exactly one attribute path."@en ;
            sh:minCount 1 ;
            sh:path nix:attrPath ] ;
    sh:targetClass nix:NixPackage .

