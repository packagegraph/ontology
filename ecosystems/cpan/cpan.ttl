# CPAN Package Ontology
@prefix cpan: <https://purl.org/packagegraph/ontology/cpan#> .
@prefix pkg: <https://purl.org/packagegraph/ontology/core#> .

@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix IAO: <http://purl.obolibrary.org/obo/IAO_> .

<https://purl.org/packagegraph/ontology/cpan#> a owl:Ontology ;
    rdfs:label "CPAN Package Ontology" ;
    rdfs:comment "Ontology for representing CPAN distributions and the Perl ecosystem" ;
    dcterms:abstract "Models CPAN (Comprehensive Perl Archive Network) distributions including modules, PAUSE author IDs, maturity levels, and CPAN-specific metadata. Instances are dual-typed as both pkg:Package and cpan:Distribution." ;
    dcterms:created "2026-04-14"^^xsd:date ;
    dcterms:license <https://creativecommons.org/publicdomain/zero/1.0/> ;
    owl:versionInfo "0.5.1" ;
    owl:imports <https://purl.org/packagegraph/ontology/core#> .

# Classes

cpan:Distribution a owl:Class ;
    rdfs:subClassOf pkg:Package ;
    rdfs:label "CPAN Distribution" ;
    rdfs:comment "A distribution published to CPAN" ;
    IAO:0000115 "A Perl distribution on CPAN containing one or more modules, described by metadata files (META.json, META.yml) and a Makefile.PL or Build.PL." .

cpan:Module a owl:Class ;
    rdfs:label "Module" ;
    rdfs:comment "A Perl module within a CPAN distribution" ;
    IAO:0000115 "A single Perl module (.pm file) that can be imported via 'use' or 'require'. A distribution may contain multiple modules." .

cpan:CPANAuthor a owl:Class ;
    rdfs:subClassOf pkg:Contributor ;
    rdfs:label "CPAN Author" ;
    rdfs:comment "A CPAN author with a PAUSE ID" ;
    IAO:0000115 "A developer registered on PAUSE (Perl Authors Upload Server) who can upload distributions to CPAN." .

cpan:CPANRepository a owl:Class ;
    rdfs:subClassOf pkg:Repository ;
    rdfs:label "CPAN Repository" ;
    rdfs:comment "A CPAN mirror or registry" ;
    IAO:0000115 "A CPAN mirror serving Perl distributions, such as cpan.org or a local minicpan." .

# Datatype Properties

cpan:authorPAUSEID a owl:DatatypeProperty ;
    rdfs:label "PAUSE ID" ;
    rdfs:domain cpan:CPANAuthor ;
    rdfs:range xsd:string ;
    IAO:0000115 "The author's PAUSE (Perl Authors Upload Server) ID, typically an uppercase handle." .

cpan:moduleName a owl:DatatypeProperty ;
    rdfs:label "module name" ;
    rdfs:domain cpan:Module ;
    rdfs:range xsd:string ;
    IAO:0000115 "The Perl module name using :: namespace separator (e.g., 'Moose::Role')." .

cpan:abstractText a owl:DatatypeProperty ;
    rdfs:label "abstract" ;
    rdfs:domain cpan:Distribution ;
    rdfs:range xsd:string ;
    IAO:0000115 "One-line description of the distribution from the META abstract field." .

cpan:maturity a owl:DatatypeProperty ;
    rdfs:label "maturity" ;
    rdfs:domain cpan:Distribution ;
    rdfs:range xsd:string ;
    IAO:0000115 "The distribution maturity level: 'released' for stable, 'developer' for development/testing versions." .

cpan:mainModule a owl:DatatypeProperty ;
    rdfs:label "main module" ;
    rdfs:domain cpan:Distribution ;
    rdfs:range xsd:string ;
    IAO:0000115 "The primary module name of the distribution (typically matches the distribution name)." .

cpan:provides a owl:DatatypeProperty ;
    rdfs:label "provides" ;
    rdfs:domain cpan:Distribution ;
    rdfs:range xsd:string ;
    IAO:0000115 "JSON-encoded list of module names provided by this distribution." .

# Object Properties

cpan:containsModule a owl:ObjectProperty ;
    rdfs:label "contains module" ;
    rdfs:domain cpan:Distribution ;
    rdfs:range cpan:Module ;
    IAO:0000115 "Associates a distribution with the modules it provides." .

cpan:uploadedBy a owl:ObjectProperty ;
    rdfs:label "uploaded by" ;
    rdfs:domain cpan:Distribution ;
    rdfs:range cpan:CPANAuthor ;
    IAO:0000115 "Associates a distribution with the CPAN author who uploaded it." .

cpan:publishedTo a owl:ObjectProperty ;
    rdfs:label "published to" ;
    rdfs:domain cpan:Distribution ;
    rdfs:range cpan:CPANRepository ;
    IAO:0000115 "Associates a distribution with the CPAN repository it was published to." .
