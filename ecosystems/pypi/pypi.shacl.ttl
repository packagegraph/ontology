@prefix pkg: <https://purl.org/packagegraph/ontology/core#> .
@prefix pypi: <https://purl.org/packagegraph/ontology/pypi#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

pypi:PypiPackageShape a sh:NodeShape ;
    sh:property [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:message "A PyPI package must have exactly one package name." ;
            sh:minCount 1 ;
            sh:path pkg:packageName ] ;
    sh:targetClass pypi:PypiPackage .

