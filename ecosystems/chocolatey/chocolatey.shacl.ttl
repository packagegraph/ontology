@prefix choco: <https://purl.org/packagegraph/ontology/chocolatey#> .
@prefix pkg: <https://purl.org/packagegraph/ontology/core#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

choco:ChocolateyPackageShape a sh:NodeShape ;
    sh:property [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:message "A Chocolatey package must have exactly one package ID."@en ;
            sh:minCount 1 ;
            sh:path pkg:packageName ] ;
    sh:targetClass choco:ChocolateyPackage .

