@prefix debian: <https://purl.org/packagegraph/ontology/deb#> .
@prefix pkg: <https://purl.org/packagegraph/ontology/core#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

debian:DebPackageShape a sh:NodeShape ;
    sh:property [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:message "A Debian package must have exactly one package name."@en ;
            sh:minCount 1 ;
            sh:path pkg:packageName ] ;
    sh:targetClass debian:DebPackage .

