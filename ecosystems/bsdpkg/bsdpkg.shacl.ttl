@prefix bsdpkg: <https://purl.org/packagegraph/ontology/bsdpkg#> .
@prefix pkg: <https://purl.org/packagegraph/ontology/core#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

bsdpkg:BinaryPackageShape a sh:NodeShape ;
    sh:property [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:message "A FreeBSD package must have exactly one package name."@en ;
            sh:minCount 1 ;
            sh:path pkg:packageName ],
        [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:message "A FreeBSD package can have at most one origin."@en ;
            sh:path bsdpkg:origin ] ;
    sh:targetClass bsdpkg:BinaryPackage .

