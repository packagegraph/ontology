@prefix apk: <https://purl.org/packagegraph/ontology/apk#> .
@prefix pkg: <https://purl.org/packagegraph/ontology/core#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

apk:ApkPackageShape a sh:NodeShape ;
    sh:property [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:message "An Alpine package must have exactly one package name." ;
            sh:minCount 1 ;
            sh:path pkg:packageName ] ;
    sh:targetClass apk:ApkPackage .

