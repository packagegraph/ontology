# NuGet Package Ontology
@prefix nuget: <https://purl.org/packagegraph/ontology/nuget#> .
@prefix pkg: <https://purl.org/packagegraph/ontology/core#> .

@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix IAO: <http://purl.obolibrary.org/obo/IAO_> .

<https://purl.org/packagegraph/ontology/nuget#> a owl:Ontology ;
    rdfs:label "NuGet Package Ontology" ;
    rdfs:comment "Ontology for representing NuGet packages and the .NET ecosystem" ;
    dcterms:abstract "Models NuGet Gallery packages including target frameworks, prerelease versions, icon URLs, tags, and framework-specific dependencies. Instances are dual-typed as both pkg:Package and nuget:NuGetPackage." ;
    dcterms:created "2026-04-14"^^xsd:date ;
    dcterms:license <https://creativecommons.org/publicdomain/zero/1.0/> ;
    owl:versionInfo "0.5.1" ;
    owl:imports <https://purl.org/packagegraph/ontology/core#> .

# Classes

nuget:NuGetPackage a owl:Class ;
    rdfs:subClassOf pkg:Package ;
    rdfs:label "NuGet Package" ;
    rdfs:comment "A package published to a NuGet feed" ;
    IAO:0000115 "A .NET library or application distributed through NuGet Gallery or private feeds, described by a .nuspec file." .

nuget:NuGetFeed a owl:Class ;
    rdfs:subClassOf pkg:Repository ;
    rdfs:label "NuGet Feed" ;
    rdfs:comment "A NuGet package feed (nuget.org or private)" ;
    IAO:0000115 "A package feed serving NuGet packages, such as nuget.org or a private Azure Artifacts/Artifactory feed." .

nuget:FrameworkGroup a owl:Class ;
    rdfs:label "Framework Group" ;
    rdfs:comment "A target framework dependency group" ;
    IAO:0000115 "A set of dependencies that apply to a specific target framework (e.g., net6.0, netstandard2.0)." .

# Datatype Properties

nuget:packageId a owl:DatatypeProperty ;
    rdfs:label "package ID" ;
    rdfs:domain nuget:NuGetPackage ;
    rdfs:range xsd:string ;
    IAO:0000115 "The NuGet package identifier (case-insensitive, typically dotted like 'Newtonsoft.Json')." .

nuget:targetFramework a owl:DatatypeProperty ;
    rdfs:label "target framework" ;
    rdfs:domain nuget:FrameworkGroup ;
    rdfs:range xsd:string ;
    IAO:0000115 "The target framework moniker (e.g., 'net6.0', 'netstandard2.0', 'net48')." .

nuget:isPrerelease a owl:DatatypeProperty ;
    rdfs:label "is prerelease" ;
    rdfs:domain nuget:NuGetPackage ;
    rdfs:range xsd:boolean ;
    IAO:0000115 "Whether this is a prerelease version (e.g., alpha, beta, rc)." .

nuget:projectUrl a owl:DatatypeProperty ;
    rdfs:label "project URL" ;
    rdfs:domain nuget:NuGetPackage ;
    rdfs:range xsd:anyURI ;
    IAO:0000115 "The project homepage URL." .

nuget:iconUrl a owl:DatatypeProperty ;
    rdfs:label "icon URL" ;
    rdfs:domain nuget:NuGetPackage ;
    rdfs:range xsd:anyURI ;
    IAO:0000115 "URL to the package icon image." .

nuget:tags a owl:DatatypeProperty ;
    rdfs:label "tags" ;
    rdfs:domain nuget:NuGetPackage ;
    rdfs:range xsd:string ;
    IAO:0000115 "Space-separated tags describing the package." .

nuget:listed a owl:DatatypeProperty ;
    rdfs:label "listed" ;
    rdfs:domain nuget:NuGetPackage ;
    rdfs:range xsd:boolean ;
    IAO:0000115 "Whether the package is listed (visible in search). Unlisted packages are hidden but still downloadable." .

# Object Properties

nuget:frameworkDependency a owl:ObjectProperty ;
    rdfs:subPropertyOf pkg:dependsOn ;
    rdfs:label "framework dependency" ;
    rdfs:domain nuget:NuGetPackage ;
    rdfs:range nuget:NuGetPackage ;
    IAO:0000115 "A framework-specific dependency (applies to specific target frameworks)." .

nuget:publishedTo a owl:ObjectProperty ;
    rdfs:label "published to" ;
    rdfs:domain nuget:NuGetPackage ;
    rdfs:range nuget:NuGetFeed ;
    IAO:0000115 "Associates a package with the NuGet feed it was published to." .
