@prefix pkg: <https://purl.org/packagegraph/ontology/core#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xbps: <https://purl.org/packagegraph/ontology/xbps#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

xbps:XbpsPackageShape a sh:NodeShape ;
    sh:property [ sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:message "A Void package must have exactly one package name." ;
            sh:minCount 1 ;
            sh:path pkg:packageName ] ;
    sh:targetClass xbps:XbpsPackage .

