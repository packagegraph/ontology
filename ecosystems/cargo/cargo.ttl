# Cargo/crates.io Package Ontology
@prefix cargo: <https://purl.org/packagegraph/ontology/cargo#> .
@prefix pkg: <https://purl.org/packagegraph/ontology/core#> .

@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix IAO: <http://purl.obolibrary.org/obo/IAO_> .

<https://purl.org/packagegraph/ontology/cargo#> a owl:Ontology ;
    rdfs:label "Cargo Package Ontology" ;
    rdfs:comment "Ontology for representing Rust crates from crates.io" ;
    dcterms:abstract "Models Rust crates including features, editions, targets (lib/bin/test/bench), build scripts, categories, and the Cargo.lock dependency resolution. Captures Rust-specific concepts like feature flags and conditional compilation." ;
    dcterms:created "2026-04-14"^^xsd:date ;
    dcterms:license <https://creativecommons.org/publicdomain/zero/1.0/> ;
    owl:versionInfo "0.5.0" ;
    owl:imports <https://purl.org/packagegraph/ontology/core#> .

# Classes

cargo:Crate a owl:Class ;
    rdfs:subClassOf pkg:Package ;
    rdfs:label "Crate" ;
    rdfs:comment "A Rust crate published to crates.io" ;
    IAO:0000115 "A Rust library or application package published to the crates.io registry, described by a Cargo.toml manifest." .

cargo:Feature a owl:Class ;
    rdfs:label "Feature" ;
    rdfs:comment "A conditional compilation feature flag" ;
    IAO:0000115 "A named feature flag in Cargo.toml that enables optional dependencies or conditional compilation via cfg attributes." .

cargo:Target a owl:Class ;
    rdfs:label "Target" ;
    rdfs:comment "A build target within a crate (lib, bin, test, bench, example)" ;
    IAO:0000115 "A compilation target defined in the crate, such as a library, binary executable, test suite, benchmark, or example." .

cargo:CrateCategory a owl:Class ;
    rdfs:label "Category" ;
    rdfs:comment "A crates.io category" ;
    IAO:0000115 "A curated category on crates.io classifying crates by functionality (e.g., 'command-line-utilities', 'web-programming', 'cryptography')." .

# Datatype Properties

cargo:edition a owl:DatatypeProperty ;
    rdfs:label "edition" ;
    rdfs:domain cargo:Crate ;
    rdfs:range xsd:string ;
    IAO:0000115 "The Rust edition the crate uses (2015, 2018, 2021, 2024), which determines language and compiler behavior." .

cargo:msrv a owl:DatatypeProperty ;
    rdfs:label "minimum supported Rust version" ;
    rdfs:domain cargo:Crate ;
    rdfs:range xsd:string ;
    IAO:0000115 "The minimum version of the Rust compiler required to build the crate (rust-version field)." .

cargo:links a owl:DatatypeProperty ;
    rdfs:label "links" ;
    rdfs:domain cargo:Crate ;
    rdfs:range xsd:string ;
    IAO:0000115 "The native library this crate links to via a build script (links field in Cargo.toml). Ensures only one crate links to a given native library." .

cargo:hasBuildScript a owl:DatatypeProperty ;
    rdfs:label "has build script" ;
    rdfs:domain cargo:Crate ;
    rdfs:range xsd:boolean ;
    IAO:0000115 "Whether the crate has a build.rs build script that runs before compilation." .

cargo:featureName a owl:DatatypeProperty ;
    rdfs:label "feature name" ;
    rdfs:domain cargo:Feature ;
    rdfs:range xsd:string ;
    IAO:0000115 "The name of the feature flag as declared in [features] in Cargo.toml." .

cargo:isDefaultFeature a owl:DatatypeProperty ;
    rdfs:label "is default feature" ;
    rdfs:domain cargo:Feature ;
    rdfs:range xsd:boolean ;
    IAO:0000115 "Whether the feature is enabled by default (listed in the 'default' feature set)." .

cargo:targetKind a owl:DatatypeProperty ;
    rdfs:label "target kind" ;
    rdfs:domain cargo:Target ;
    rdfs:range xsd:string ;
    IAO:0000115 "The kind of build target: lib, bin, test, bench, example, or proc-macro." .

cargo:targetName a owl:DatatypeProperty ;
    rdfs:label "target name" ;
    rdfs:domain cargo:Target ;
    rdfs:range xsd:string ;
    IAO:0000115 "The name of the build target, used as the binary name or library identifier." .

cargo:downloads a owl:DatatypeProperty ;
    rdfs:label "downloads" ;
    rdfs:domain cargo:Crate ;
    rdfs:range xsd:integer ;
    IAO:0000115 "Total download count from crates.io (point-in-time claim, not ground truth)." .

cargo:categorySlug a owl:DatatypeProperty ;
    rdfs:label "category slug" ;
    rdfs:domain cargo:CrateCategory ;
    rdfs:range xsd:string ;
    IAO:0000115 "The URL slug identifying the category on crates.io." .

cargo:crateChecksum a owl:DatatypeProperty ;
    rdfs:label "crate checksum" ;
    rdfs:domain cargo:Crate ;
    rdfs:range xsd:string ;
    IAO:0000115 "SHA-256 checksum of the .crate archive from the crates.io index." .

# Object Properties

cargo:hasFeature a owl:ObjectProperty ;
    rdfs:label "has feature" ;
    rdfs:domain cargo:Crate ;
    rdfs:range cargo:Feature ;
    IAO:0000115 "Associates a crate with a feature flag it defines." .

cargo:hasTarget a owl:ObjectProperty ;
    rdfs:label "has target" ;
    rdfs:domain cargo:Crate ;
    rdfs:range cargo:Target ;
    IAO:0000115 "Associates a crate with a build target it provides." .

cargo:inCategory a owl:ObjectProperty ;
    rdfs:label "in category" ;
    rdfs:domain cargo:Crate ;
    rdfs:range cargo:CrateCategory ;
    IAO:0000115 "Associates a crate with a crates.io category." .

cargo:featureEnables a owl:ObjectProperty ;
    rdfs:label "feature enables" ;
    rdfs:domain cargo:Feature ;
    rdfs:range cargo:Feature ;
    IAO:0000115 "A feature that is transitively enabled when this feature is activated." .

cargo:devDependsOn a owl:ObjectProperty ;
    rdfs:subPropertyOf pkg:dependsOn ;
    rdfs:label "dev depends on" ;
    rdfs:domain cargo:Crate ;
    rdfs:range cargo:Crate ;
    IAO:0000115 "A development-only dependency used for tests, benchmarks, and examples." .

cargo:buildDependsOn a owl:ObjectProperty ;
    rdfs:subPropertyOf pkg:buildDependsOn ;
    rdfs:label "build depends on" ;
    rdfs:domain cargo:Crate ;
    rdfs:range cargo:Crate ;
    IAO:0000115 "A dependency required only by the build script (build.rs)." .
