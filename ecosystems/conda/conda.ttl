# Conda/Anaconda Package Ontology
@prefix conda: <https://purl.org/packagegraph/ontology/conda#> .
@prefix pkg: <https://purl.org/packagegraph/ontology/core#> .

@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix IAO: <http://purl.obolibrary.org/obo/IAO_> .

<https://purl.org/packagegraph/ontology/conda#> a owl:Ontology ;
    rdfs:label "Conda Package Ontology" ;
    rdfs:comment "Ontology for representing Conda packages, channels, and environments" ;
    dcterms:abstract "Models the Conda ecosystem including packages from Anaconda defaults and conda-forge channels, environments, recipes, feedstocks, and noarch packages. Captures build strings, build numbers, and subdirectory/platform targeting." ;
    dcterms:created "2026-04-14"^^xsd:date ;
    dcterms:license <https://creativecommons.org/publicdomain/zero/1.0/> ;
    owl:versionInfo "0.5.0" ;
    owl:imports <https://purl.org/packagegraph/ontology/core#> .

# Classes

conda:CondaPackage a owl:Class ;
    rdfs:subClassOf pkg:Package ;
    rdfs:label "Conda Package" ;
    rdfs:comment "A package distributed through a Conda channel" ;
    IAO:0000115 "A package in Conda format (.conda or .tar.bz2) containing pre-built binaries, metadata, and installation scripts, managed by the conda package manager." .

conda:Channel a owl:Class ;
    rdfs:subClassOf pkg:Repository ;
    rdfs:label "Channel" ;
    rdfs:comment "A Conda package channel (e.g., defaults, conda-forge)" ;
    IAO:0000115 "A Conda package repository hosting packages for one or more platforms/subdirectories, such as the Anaconda defaults channel or the community-maintained conda-forge." .

conda:Environment a owl:Class ;
    rdfs:label "Environment" ;
    rdfs:comment "A Conda environment with a resolved set of packages" ;
    IAO:0000115 "An isolated Conda environment containing a specific set of resolved packages, described by an environment.yml file." .

conda:Recipe a owl:Class ;
    rdfs:label "Recipe" ;
    rdfs:comment "A conda-build recipe (meta.yaml)" ;
    IAO:0000115 "A build recipe in meta.yaml format describing how to build a Conda package from source, including dependencies, build scripts, and test commands." .

conda:Feedstock a owl:Class ;
    rdfs:label "Feedstock" ;
    rdfs:comment "A conda-forge feedstock repository" ;
    IAO:0000115 "A Git repository in the conda-forge organization containing a Conda recipe and CI configuration for automated package building." .

# Datatype Properties

conda:buildString a owl:DatatypeProperty ;
    rdfs:label "build string" ;
    rdfs:domain conda:CondaPackage ;
    rdfs:range xsd:string ;
    IAO:0000115 "The build string identifying the specific build variant, e.g., 'py312h1234567_0'." .

conda:buildNumber a owl:DatatypeProperty ;
    rdfs:label "build number" ;
    rdfs:domain conda:CondaPackage ;
    rdfs:range xsd:integer ;
    IAO:0000115 "The build iteration number, incremented when the recipe changes without a version bump." .

conda:subdirectory a owl:DatatypeProperty ;
    rdfs:label "subdirectory" ;
    rdfs:domain conda:CondaPackage ;
    rdfs:range xsd:string ;
    IAO:0000115 "The platform subdirectory (e.g., 'linux-64', 'osx-arm64', 'noarch') the package targets." .

conda:noarch a owl:DatatypeProperty ;
    rdfs:label "noarch" ;
    rdfs:domain conda:CondaPackage ;
    rdfs:range xsd:string ;
    IAO:0000115 "Noarch type: 'python' for pure-Python packages or 'generic' for platform-independent data packages." .

conda:constrains a owl:DatatypeProperty ;
    rdfs:label "constrains" ;
    rdfs:domain conda:CondaPackage ;
    rdfs:range xsd:string ;
    IAO:0000115 "Version constraints on packages that are NOT required but must satisfy the constraint if installed." .

conda:timestamp a owl:DatatypeProperty ;
    rdfs:label "timestamp" ;
    rdfs:domain conda:CondaPackage ;
    rdfs:range xsd:long ;
    IAO:0000115 "Unix timestamp of when the package was built." .

conda:md5 a owl:DatatypeProperty ;
    rdfs:label "md5" ;
    rdfs:domain conda:CondaPackage ;
    rdfs:range xsd:string ;
    IAO:0000115 "MD5 hash of the package archive for integrity verification." .

conda:sha256 a owl:DatatypeProperty ;
    rdfs:label "sha256" ;
    rdfs:domain conda:CondaPackage ;
    rdfs:range xsd:string ;
    IAO:0000115 "SHA-256 hash of the package archive." .

conda:channelUrl a owl:DatatypeProperty ;
    rdfs:label "channel URL" ;
    rdfs:domain conda:Channel ;
    rdfs:range xsd:string ;
    IAO:0000115 "The base URL of the Conda channel." .

# Object Properties

conda:inChannel a owl:ObjectProperty ;
    rdfs:label "in channel" ;
    rdfs:domain conda:CondaPackage ;
    rdfs:range conda:Channel ;
    IAO:0000115 "Associates a package with the Conda channel it is distributed through." .

conda:inEnvironment a owl:ObjectProperty ;
    rdfs:label "in environment" ;
    rdfs:domain conda:CondaPackage ;
    rdfs:range conda:Environment ;
    IAO:0000115 "Associates a package with a Conda environment it is installed in." .

conda:builtFromRecipe a owl:ObjectProperty ;
    rdfs:label "built from recipe" ;
    rdfs:domain conda:CondaPackage ;
    rdfs:range conda:Recipe ;
    IAO:0000115 "Associates a package with the conda-build recipe used to produce it." .

conda:hasFeedstock a owl:ObjectProperty ;
    rdfs:label "has feedstock" ;
    rdfs:domain conda:Recipe ;
    rdfs:range conda:Feedstock ;
    IAO:0000115 "Associates a recipe with its conda-forge feedstock repository." .

conda:runDependsOn a owl:ObjectProperty ;
    rdfs:subPropertyOf pkg:dependsOn ;
    rdfs:label "run depends on" ;
    rdfs:domain conda:CondaPackage ;
    rdfs:range conda:CondaPackage ;
    IAO:0000115 "A runtime dependency required when the package is installed." .

conda:hostDependsOn a owl:ObjectProperty ;
    rdfs:subPropertyOf pkg:buildDependsOn ;
    rdfs:label "host depends on" ;
    rdfs:domain conda:CondaPackage ;
    rdfs:range conda:CondaPackage ;
    IAO:0000115 "A host dependency needed during build for the target platform (cross-compilation)." .
