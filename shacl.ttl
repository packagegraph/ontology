@prefix sh:    <http://www.w3.org/ns/shacl#> .
@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix pkg:   <https://purl.org/packagegraph/ontology/core#> .
@prefix sec:   <https://purl.org/packagegraph/ontology/security#> .
@prefix met:   <https://purl.org/packagegraph/ontology/metrics#> .
@prefix rpm:   <https://purl.org/packagegraph/ontology/rpm#> .
@prefix slsa:  <https://purl.org/packagegraph/ontology/slsa#> .
@prefix vcs:   <https://purl.org/packagegraph/ontology/vcs#> .
@prefix prov:  <http://www.w3.org/ns/prov#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix debian: <https://purl.org/packagegraph/ontology/debian#> .
@prefix alpine: <https://purl.org/packagegraph/ontology/alpine#> .
@prefix arch:  <https://purl.org/packagegraph/ontology/archlinux#> .
@prefix homebrew: <https://purl.org/packagegraph/ontology/homebrew#> .
@prefix npm:   <https://purl.org/packagegraph/ontology/npm#> .
@prefix pypi:  <https://purl.org/packagegraph/ontology/pypi#> .
@prefix cargo: <https://purl.org/packagegraph/ontology/cargo#> .
@prefix gomod: <https://purl.org/packagegraph/ontology/gomod#> .
@prefix conda: <https://purl.org/packagegraph/ontology/conda#> .
@prefix flatpak: <https://purl.org/packagegraph/ontology/flatpak#> .
@prefix snap:  <https://purl.org/packagegraph/ontology/snap#> .
@prefix gentoo: <https://purl.org/packagegraph/ontology/gentoo#> .
@prefix void:  <https://purl.org/packagegraph/ontology/void#> .
@prefix rubygems: <https://purl.org/packagegraph/ontology/rubygems#> .
@prefix maven: <https://purl.org/packagegraph/ontology/maven#> .
@prefix cpan:  <https://purl.org/packagegraph/ontology/cpan#> .
@prefix cran:  <https://purl.org/packagegraph/ontology/cran#> .
@prefix hackage: <https://purl.org/packagegraph/ontology/hackage#> .
@prefix nuget: <https://purl.org/packagegraph/ontology/nuget#> .
@prefix hex:   <https://purl.org/packagegraph/ontology/hex#> .
@prefix freebsd: <https://purl.org/packagegraph/ontology/freebsd#> .
@prefix nix:   <https://purl.org/packagegraph/ontology/nix#> .
@prefix choco: <https://purl.org/packagegraph/ontology/chocolatey#> .

<https://purl.org/packagegraph/ontology/shacl#>
  a owl:Ontology ;
  rdfs:label "PackageGraph SHACL Validation Shapes" ;
  rdfs:comment "Provides data validation rules for the PackageGraph ontology suite." ;
  dcterms:abstract "SHACL (Shapes Constraint Language) shapes for validating PackageGraph RDF data. These shapes enforce required properties, cardinality constraints, and value types on package, version, dependency, and maintainer instances, catching data quality issues before they reach the SPARQL endpoint." ;
  dcterms:created "2025-09-05"^^xsd:date ;
  dcterms:creator "Package Management Ontology Project" ;
  dcterms:title "PackageGraph SHACL Validation Shapes" ;
  dcterms:description "SHACL shapes for validating data conformance to the PackageGraph ontology, including required property checks, cardinality constraints, and datatype validation." ;
  dcterms:license <https://creativecommons.org/publicdomain/zero/1.0/> ;
  owl:versionInfo "0.5.0" .

# Shape for core:Package
pkg:PackageShape
  a sh:NodeShape ;
  sh:targetClass pkg:Package ;
  sh:property [
    sh:path pkg:hasVersion ;
    sh:minCount 1 ;
    sh:message "A package must have at least one version."
  ] ;
  sh:property [
    sh:path pkg:packageName ;
    sh:maxCount 1 ;
    sh:message "A package must have exactly one package name."
  ] ;
  sh:property [
    sh:path pkg:homepage ;
    sh:maxCount 1 ;
    sh:message "A package can have at most one homepage."
  ] ;
  sh:property [
    sh:path pkg:downloadURL ;
    sh:maxCount 1 ;
    sh:message "A package can have at most one download URL."
  ] ;
  sh:property [
    sh:path pkg:checksum ;
    sh:maxCount 1 ;
    sh:message "A package can have at most one checksum."
  ] ;
  sh:property [
    sh:path pkg:maintainedBy ;
    sh:class pkg:Maintainer ;
    sh:message "The value of pkg:maintainedBy must be a pkg:Maintainer."
  ] .

# Shape for core:Version
pkg:VersionShape
  a sh:NodeShape ;
  sh:targetClass pkg:Version ;
  sh:property [
    sh:path pkg:versionString ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:datatype xsd:string ;
    sh:message "A version must have exactly one version string."
  ] .

# Shape for core:Maintainer
pkg:MaintainerShape
    a sh:NodeShape ;
    sh:targetClass pkg:Maintainer ;
    sh:property [
        sh:path <http://xmlns.com/foaf/0.1/name> ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:message "A maintainer must have exactly one foaf:name."
    ] .

# Shape for security:Vulnerability
sec:VulnerabilityShape
  a sh:NodeShape ;
  sh:targetClass sec:Vulnerability ;
  sh:property [
    sh:path sec:cveId ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:datatype xsd:string ;
    sh:message "A vulnerability must have exactly one CVE identifier."
  ] ;
  sh:property [
    sh:path sec:cvssScore ;
    sh:maxCount 1 ;
    sh:datatype xsd:float ;
    sh:message "A vulnerability can have at most one CVSS score."
  ] .

# Shape for security:SecurityAdvisory
sec:SecurityAdvisoryShape
  a sh:NodeShape ;
  sh:targetClass sec:SecurityAdvisory ;
  sh:property [
    sh:path sec:advisoryId ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:datatype xsd:string ;
    sh:message "A security advisory must have exactly one advisory identifier."
  ] .

# Shape for metrics:ProgrammingLanguage
met:ProgrammingLanguageShape
  a sh:NodeShape ;
  sh:targetClass met:ProgrammingLanguage ;
  sh:property [
    sh:path met:languageName ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:datatype xsd:string ;
    sh:message "A programming language must have exactly one language name."
  ] ;
  sh:property [
    sh:path met:isMemorySafe ;
    sh:maxCount 1 ;
    sh:datatype xsd:boolean ;
    sh:message "A programming language can have at most one memory safety indicator."
  ] .

# Shape for metrics:CodeMetrics
met:CodeMetricsShape
  a sh:NodeShape ;
  sh:targetClass met:CodeMetrics ;
  sh:property [
    sh:path met:hasLanguageMetrics ;
    sh:minCount 1 ;
    sh:message "Code metrics must have at least one language metrics breakdown."
  ] .

# Shape for rpm:Patch
rpm:PatchShape
  a sh:NodeShape ;
  sh:targetClass rpm:Patch ;
  sh:property [
    sh:path rpm:patchName ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:datatype xsd:string ;
    sh:message "A patch must have exactly one patch name."
  ] .

# Shape for core:PackageSet
pkg:PackageSetShape
  a sh:NodeShape ;
  sh:targetClass pkg:PackageSet ;
  sh:property [
    sh:path rdfs:label ;
    sh:minCount 1 ;
    sh:datatype xsd:string ;
    sh:message "A package set must have at least one label."
  ] .

# Shape for core:SourcePackage
pkg:SourcePackageShape
  a sh:NodeShape ;
  sh:targetClass pkg:SourcePackage .

# Shape for core:BinaryPackage
pkg:BinaryPackageShape
  a sh:NodeShape ;
  sh:targetClass pkg:BinaryPackage ;
  sh:property [
    sh:path pkg:builtFromSource ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:class pkg:SourcePackage ;
    sh:message "A binary package must be built from exactly one source package."
  ] .

# Shape for core:UpstreamProject
pkg:UpstreamProjectShape
  a sh:NodeShape ;
  sh:targetClass pkg:UpstreamProject ;
  sh:property [
    sh:path pkg:projectName ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:datatype xsd:string ;
    sh:message "An upstream project must have exactly one project name."
  ] .

# Shape for core:DistributionRelease
pkg:DistributionReleaseShape
  a sh:NodeShape ;
  sh:targetClass pkg:DistributionRelease ;
  sh:property [
    sh:path rdfs:label ;
    sh:minCount 1 ;
    sh:datatype xsd:string ;
    sh:message "A distribution release must have at least one label."
  ] .

# Shape for core:ContributorAccount
pkg:ContributorAccountShape
  a sh:NodeShape ;
  sh:targetClass pkg:ContributorAccount ;
  sh:property [
    sh:path pkg:accountPlatform ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:datatype xsd:string ;
    sh:message "A contributor account must have exactly one platform."
  ] ;
  sh:property [
    sh:path pkg:accountUsername ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:datatype xsd:string ;
    sh:message "A contributor account must have exactly one username."
  ] .

# Shape for core:InstalledFile
pkg:InstalledFileShape
  a sh:NodeShape ;
  sh:targetClass pkg:InstalledFile ;
  sh:property [
    sh:path pkg:installedFilePath ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:datatype xsd:string ;
    sh:message "An installed file must have exactly one file path."
  ] .

# Shape for core:BuildActivity (PROV-O grounding)
pkg:BuildActivityShape
  a sh:NodeShape ;
  sh:targetClass pkg:BuildActivity ;
  sh:property [
    sh:path pkg:performedBy ;
    sh:class prov:Agent ;
    sh:message "A build activity's performer must be a prov:Agent."
  ] .

# Shape for slsa:ProvenanceAttestation
slsa:ProvenanceAttestationShape
  a sh:NodeShape ;
  sh:targetClass slsa:ProvenanceAttestation ;
  sh:property [
    sh:path slsa:attestsBuildLevel ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:class slsa:BuildLevel ;
    sh:message "A provenance attestation must attest exactly one SLSA build level."
  ] ;
  sh:property [
    sh:path slsa:attestationTimestamp ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:datatype xsd:dateTime ;
    sh:message "A provenance attestation must have exactly one timestamp."
  ] ;
  sh:property [
    sh:path slsa:attestationDigest ;
    sh:minCount 1 ;
    sh:datatype xsd:string ;
    sh:message "A provenance attestation must have at least one artifact digest."
  ] .

# Shape for slsa:Builder
slsa:BuilderShape
  a sh:NodeShape ;
  sh:targetClass slsa:Builder ;
  sh:property [
    sh:path slsa:builderId ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:datatype xsd:anyURI ;
    sh:message "A builder must have exactly one builder ID URI."
  ] .

# Shape for slsa:BuildEnvironment
slsa:BuildEnvironmentShape
  a sh:NodeShape ;
  sh:targetClass slsa:BuildEnvironment ;
  sh:property [
    sh:path slsa:isEphemeral ;
    sh:maxCount 1 ;
    sh:datatype xsd:boolean ;
    sh:message "A build environment can have at most one ephemeral flag."
  ] ;
  sh:property [
    sh:path slsa:isIsolated ;
    sh:maxCount 1 ;
    sh:datatype xsd:boolean ;
    sh:message "A build environment can have at most one isolated flag."
  ] .

# Shape for vcs:Commit (PROV-O grounding)
vcs:CommitShape
  a sh:NodeShape ;
  sh:targetClass vcs:Commit ;
  sh:property [
    sh:path vcs:commitHash ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:datatype xsd:string ;
    sh:message "A commit must have exactly one commit hash."
  ] ;
  sh:property [
    sh:path vcs:commitTimestamp ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:datatype xsd:dateTime ;
    sh:message "A commit must have exactly one timestamp."
  ] ;
  sh:property [
    sh:path vcs:authoredBy ;
    sh:class pkg:Contributor ;
    sh:message "A commit's author must be a pkg:Contributor."
  ] .

# Shape for sec:PatchActivity (supply chain provenance)
sec:PatchActivityShape
  a sh:NodeShape ;
  sh:targetClass sec:PatchActivity ;
  sh:property [
    sh:path sec:patchAddresses ;
    sh:minCount 1 ;
    sh:class sec:Vulnerability ;
    sh:message "A patch activity must address at least one vulnerability."
  ] .

# Ecosystem-Specific Package Shapes

