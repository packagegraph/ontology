    sh:maxCount 1 ;
    sh:datatype xsd:string ;
    sh:message "A CRAN package must have exactly one package name."
  ] ;
  sh:property [
    sh:path cran:needsCompilation ;
    sh:maxCount 1 ;
    sh:datatype xsd:boolean ;
    sh:message "A CRAN package can have at most one needs compilation flag."
  ] .

# Hackage
hackage:HackagePackageShape
  a sh:NodeShape ;
  sh:targetClass hackage:HackagePackage ;
  sh:property [
    sh:path pkg:packageName ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:datatype xsd:string ;
    sh:message "A Hackage package must have exactly one package name."
  ] .

