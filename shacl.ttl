    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:datatype xsd:string ;
    sh:message "A NuGet package must have exactly one package ID."
  ] ;
  sh:property [
    sh:path nuget:isPrerelease ;
    sh:maxCount 1 ;
    sh:datatype xsd:boolean ;
    sh:message "A NuGet package can have at most one prerelease flag."
  ] .

# Hex
hex:HexPackageShape
  a sh:NodeShape ;
  sh:targetClass hex:HexPackage ;
  sh:property [
    sh:path pkg:packageName ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:datatype xsd:string ;
    sh:message "A Hex package must have exactly one package name."
  ] .

# FreeBSD
bsdpkg:BinaryPackageShape
  a sh:NodeShape ;
  sh:targetClass bsdpkg:BinaryPackage ;
  sh:property [
    sh:path pkg:packageName ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:datatype xsd:string ;
    sh:message "A FreeBSD package must have exactly one package name."
  ] ;
  sh:property [
    sh:path bsdpkg:origin ;
    sh:maxCount 1 ;
    sh:datatype xsd:string ;
    sh:message "A FreeBSD package can have at most one origin."
  ] .

# Nix
nix:NixPackageShape
  a sh:NodeShape ;
  sh:targetClass nix:NixPackage ;
  sh:property [
    sh:path pkg:packageName ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:datatype xsd:string ;
    sh:message "A Nix package must have exactly one package name."
  ] ;
  sh:property [
    sh:path nix:attrPath ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:datatype xsd:string ;
    sh:message "A Nix package must have exactly one attribute path."
  ] .

# Chocolatey
choco:ChocolateyPackageShape
  a sh:NodeShape ;
  sh:targetClass choco:ChocolateyPackage ;
  sh:property [
    sh:path pkg:packageName ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:datatype xsd:string ;
    sh:message "A Chocolatey package must have exactly one package ID."
  ] .

# Package URL (PURL) validation shape
pkg:PURLShape
  a sh:NodeShape ;
  sh:targetClass pkg:PackageIdentity ;
  sh:property [
    sh:path pkg:purl ;
    sh:maxCount 1 ;
    sh:datatype xsd:anyURI ;
    sh:pattern "^pkg:[a-z]+/.+@.+" ;
    sh:message "A PURL must follow the format pkg:type/namespace/name@version"
  ] .

# =============================================================================
# Embedded Linux Build System Shapes
# =============================================================================

# Yocto Recipe Shape
bitbake:BitBakeRecipeShape
  a sh:NodeShape ;
  sh:targetClass bitbake:BitBakeRecipe ;
  sh:property [
    sh:path pkg:packageName ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:datatype xsd:string ;
    sh:message "A Yocto recipe must have exactly one package name."
  ] ;
  sh:property [
    sh:path bitbake:layer ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:datatype xsd:string ;
    sh:message "A Yocto recipe must belong to exactly one layer."
  ] ;
  sh:property [
    sh:path bitbake:pv ;
    sh:maxCount 1 ;
    sh:datatype xsd:string ;
    sh:message "A Yocto recipe can have at most one PV (version)."
  ] ;
  sh:property [
    sh:path bitbake:licFilesChksum ;
    sh:datatype xsd:string ;
    sh:message "LIC_FILES_CHKSUM must be a string."
  ] .

# Yocto Layer Shape
bitbake:LayerShape
  a sh:NodeShape ;
  sh:targetClass bitbake:Layer ;
  sh:property [
    sh:path bitbake:layerName ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:datatype xsd:string ;
    sh:message "A Yocto layer must have exactly one layer name."
  ] ;
  sh:property [
    sh:path bitbake:layerPriority ;
    sh:maxCount 1 ;
    sh:datatype xsd:integer ;
    sh:message "A Yocto layer can have at most one priority."
  ] .

# Yocto Machine Shape
bitbake:MachineShape
  a sh:NodeShape ;
  sh:targetClass bitbake:Machine ;
  sh:property [
    sh:path bitbake:machineName ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:datatype xsd:string ;
    sh:message "A Yocto machine must have exactly one machine name."
  ] .

# Yocto BitBake Class Shape
bitbake:BitBakeClassShape
  a sh:NodeShape ;
  sh:targetClass bitbake:BitBakeClass ;
  sh:property [
    sh:path bitbake:className ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:datatype xsd:string ;
    sh:message "A BitBake class must have exactly one class name."
  ] .

# Yocto Image Shape
bitbake:ImageShape
  a sh:NodeShape ;
  sh:targetClass bitbake:Image ;
  sh:property [
    sh:path bitbake:imageName ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:datatype xsd:string ;
    sh:message "A Yocto image must have exactly one image name."
  ] .

# Buildroot Package Shape
buildroot:BuildrootPackageShape
  a sh:NodeShape ;
  sh:targetClass buildroot:BuildrootPackage ;
  sh:property [
    sh:path pkg:packageName ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:datatype xsd:string ;
    sh:message "A Buildroot package must have exactly one package name."
  ] ;
  sh:property [
    sh:path buildroot:installStaging ;
    sh:maxCount 1 ;
    sh:datatype xsd:boolean ;
    sh:message "A Buildroot package can have at most one install-staging flag."
  ] ;
  sh:property [
    sh:path buildroot:installTarget ;
    sh:maxCount 1 ;
    sh:datatype xsd:boolean ;
    sh:message "A Buildroot package can have at most one install-target flag."
  ] ;
  sh:property [
    sh:path buildroot:cpeVendor ;
    sh:maxCount 1 ;
    sh:datatype xsd:string ;
    sh:message "A Buildroot package can have at most one CPE vendor."
  ] ;
  sh:property [
    sh:path buildroot:cpeProduct ;
    sh:maxCount 1 ;
    sh:datatype xsd:string ;
    sh:message "A Buildroot package can have at most one CPE product."
  ] ;
  sh:property [
    sh:path buildroot:site ;
    sh:maxCount 1 ;
    sh:datatype xsd:string ;
    sh:message "A Buildroot package can have at most one download site."
  ] ;
  sh:property [
    sh:path buildroot:siteMethod ;
    sh:maxCount 1 ;
    sh:datatype xsd:string ;
    sh:pattern "^(wget|git|svn|hg|bzr|file|local|scp|cvs)$" ;
    sh:message "Buildroot site method must be a known download method (wget, git, svn, hg, bzr, file, local, scp, cvs)."
  ] .

# Buildroot Build Infrastructure Shape
buildroot:BuildInfrastructureShape
  a sh:NodeShape ;
  sh:targetClass buildroot:BuildInfrastructure ;
  sh:property [
    sh:path rdfs:label ;
    sh:minCount 1 ;
    sh:datatype xsd:string ;
    sh:message "A build infrastructure must have at least one label."
  ] .

# Buildroot Defconfig Shape
buildroot:DefconfigShape
  a sh:NodeShape ;
  sh:targetClass buildroot:Defconfig ;
  sh:property [
    sh:path buildroot:defconfigName ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:datatype xsd:string ;
    sh:message "A defconfig must have exactly one name."
  ] .

# OpenWRT Package Shape
opkg:OpkgPackageShape
  a sh:NodeShape ;
  sh:targetClass opkg:OpkgPackage ;
  sh:property [
    sh:path pkg:packageName ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:datatype xsd:string ;
    sh:message "An OpenWRT package must have exactly one package name."
  ] ;
  sh:property [
    sh:path opkg:feed ;
    sh:maxCount 1 ;
    sh:datatype xsd:string ;
    sh:message "An OpenWRT package can belong to at most one feed."
  ] ;
  sh:property [
    sh:path opkg:category ;
    sh:maxCount 1 ;
    sh:datatype xsd:string ;
    sh:message "An OpenWRT package can have at most one category."
  ] ;
  sh:property [
    sh:path opkg:title ;
    sh:maxCount 1 ;
    sh:datatype xsd:string ;
    sh:message "An OpenWRT package can have at most one title."
  ] ;
  sh:property [
    sh:path opkg:defaultEnabled ;
    sh:maxCount 1 ;
    sh:datatype xsd:boolean ;
    sh:message "An OpenWRT package can have at most one default-enabled flag."
  ] .

# OpenWRT Kernel Module Shape
opkg:KernelModuleShape
  a sh:NodeShape ;
  sh:targetClass opkg:KernelModule ;
  sh:property [
    sh:path opkg:autoload ;
    sh:maxCount 1 ;
    sh:datatype xsd:string ;
    sh:message "A kernel module can have at most one autoload configuration."
  ] .

# OpenWRT Feed Shape
opkg:FeedShape
  a sh:NodeShape ;
  sh:targetClass opkg:Feed ;
  sh:property [
    sh:path rdfs:label ;
    sh:minCount 1 ;
    sh:datatype xsd:string ;
    sh:message "A feed must have at least one label."
  ] .

# OpenWRT Target Shape
opkg:TargetShape
  a sh:NodeShape ;
  sh:targetClass opkg:Target ;
  sh:property [
    sh:path opkg:targetName ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:datatype xsd:string ;
    sh:message "A target must have exactly one target name."
  ] .

# OpenWRT Device Profile Shape
opkg:DeviceProfileShape
  a sh:NodeShape ;
  sh:targetClass opkg:DeviceProfile ;
  sh:property [
    sh:path opkg:profileName ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:datatype xsd:string ;
    sh:message "A device profile must have exactly one profile name."
  ] ;
  sh:property [
    sh:path opkg:flashSize ;
    sh:maxCount 1 ;
    sh:datatype xsd:integer ;
    sh:message "A device profile can have at most one flash size."
  ] ;
  sh:property [
    sh:path opkg:ramSize ;
    sh:maxCount 1 ;
    sh:datatype xsd:integer ;
    sh:message "A device profile can have at most one RAM size."
  ] .

# CPE identifier validation shape
sec:CPEShape
  a sh:NodeShape ;
  sh:targetClass pkg:PackageIdentity ;
  sh:property [
    sh:path sec:cpeId ;
    sh:maxCount 1 ;
    sh:datatype xsd:string ;
    sh:pattern "^cpe:2\\.3:[aho]:[^:]+:[^:]+:[^:]+:[^:]*:[^:]*:[^:]*:[^:]*:[^:]*:[^:]*:[^:]*$" ;
    sh:message "A CPE identifier must follow CPE 2.3 format: cpe:2.3:part:vendor:product:version:update:edition:language:sw_edition:target_sw:target_hw:other"
  ] .
