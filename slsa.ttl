# SLSA Supply Chain Security Ontology
@prefix slsa: <https://purl.org/packagegraph/ontology/slsa#> .
@prefix pkg: <https://purl.org/packagegraph/ontology/core#> .
@prefix sec: <https://purl.org/packagegraph/ontology/security#> .
@prefix vcs: <https://purl.org/packagegraph/ontology/vcs#> .

@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix IAO: <http://purl.obolibrary.org/obo/IAO_> .


# Ontology Declaration
<https://purl.org/packagegraph/ontology/slsa#> a owl:Ontology ;
    rdfs:label "SLSA Supply Chain Security Ontology" ;
    rdfs:comment "Ontology for representing SLSA (Supply-chain Levels for Software Artifacts) provenance attestations, build levels, and supply chain verification metadata" ;
    dcterms:abstract "The SLSA ontology models supply chain provenance according to the SLSA v1.0 specification. It provides classes for provenance attestations, build environments, and SLSA level compliance, grounded in PROV-O. Attestations link to pkg:BuildActivity and pkg:DataSnapshot, enabling SPARQL queries such as finding all packages with SLSA L3 provenance or identifying packages built on unattested infrastructure." ;
    dcterms:created "2026-04-13"^^xsd:date ;
    dcterms:creator "PackageGraph Project" ;
    dcterms:title "SLSA Supply Chain Security Ontology" ;
    dcterms:description "Models SLSA provenance attestations, build levels, builder identity, and source-to-artifact verification chains for software supply chain security." ;
    dcterms:license <https://creativecommons.org/publicdomain/zero/1.0/> ;
    owl:versionInfo "0.5.0" ;
    owl:imports <core.ttl> , <security.ttl> , <vcs.ttl> .


# #################################################################
# #
# #    Classes
# #
# #################################################################

slsa:ProvenanceAttestation a owl:Class ;
    rdfs:subClassOf prov:Entity ;
    rdfs:label "Provenance Attestation" ;
    rdfs:comment "A signed statement about the provenance of a software artifact" ;
    IAO:0000115 "A cryptographically signed document that attests to the build provenance of a software artifact, conforming to the in-toto attestation framework and SLSA provenance predicate." .

slsa:BuildLevel a owl:Class ;
    rdfs:subClassOf owl:Thing ;
    rdfs:label "SLSA Build Level" ;
    rdfs:comment "A SLSA build level indicating the degree of supply chain integrity" ;
    IAO:0000115 "A specific SLSA build level (L0-L3) that classifies the supply chain security posture of a software artifact based on its build provenance, isolation, and verification properties." .

slsa:Builder a owl:Class ;
    rdfs:subClassOf prov:Agent ;
    rdfs:label "Builder" ;
    rdfs:comment "A build platform or service that produces software artifacts" ;
    IAO:0000115 "A build platform, CI/CD service, or build system that executes the build process and produces software artifacts, such as GitHub Actions, Koji, or OBS." .

slsa:SourceAttestation a owl:Class ;
    rdfs:subClassOf prov:Entity ;
    rdfs:label "Source Attestation" ;
    rdfs:comment "An attestation about the source code and its version control provenance" ;
    IAO:0000115 "A statement attesting to the integrity and provenance of the source code used in a build, including its version control origin, review status, and two-party review compliance." .

slsa:BuildEnvironment a owl:Class ;
    rdfs:subClassOf prov:Entity ;
    rdfs:label "Build Environment" ;
    rdfs:comment "The environment in which a build was executed" ;
    IAO:0000115 "A description of the build environment including the operating system, toolchain, container image, and isolation properties used during a build activity." .


# #################################################################
# #
# #    SLSA Build Level Individuals
# #
# #################################################################

slsa:L0 a owl:NamedIndividual, slsa:BuildLevel ;
    rdfs:label "SLSA L0" ;
    rdfs:comment "No SLSA guarantees — no provenance" ;
    IAO:0000115 "SLSA Build Level 0: no provenance attestation exists. The artifact has no supply chain integrity guarantees." .

slsa:L1 a owl:NamedIndividual, slsa:BuildLevel ;
    rdfs:label "SLSA L1" ;
    rdfs:comment "Provenance exists — the build process is documented" ;
    IAO:0000115 "SLSA Build Level 1: provenance attestation exists, indicating the build process is documented. The provenance may be generated by the build system itself." .

slsa:L2 a owl:NamedIndividual, slsa:BuildLevel ;
    rdfs:label "SLSA L2" ;
    rdfs:comment "Hosted build — provenance generated by a hosted build service" ;
    IAO:0000115 "SLSA Build Level 2: provenance is generated by a hosted build service with tamper-resistant provenance generation. The build runs on a managed platform." .

slsa:L3 a owl:NamedIndividual, slsa:BuildLevel ;
    rdfs:label "SLSA L3" ;
    rdfs:comment "Hardened builds — isolated, ephemeral build environments" ;
    IAO:0000115 "SLSA Build Level 3: builds are executed in isolated, ephemeral environments with hardened infrastructure. Provenance is non-falsifiable by the build service tenants." .


# #################################################################
# #
# #    Datatype Properties — ProvenanceAttestation
# #
# #################################################################

slsa:predicateType a owl:DatatypeProperty, owl:FunctionalProperty ;
    rdfs:label "predicate type" ;
    rdfs:comment "The in-toto predicate type URI for this attestation" ;
    rdfs:domain slsa:ProvenanceAttestation ;
    rdfs:range xsd:anyURI ;
    IAO:0000115 "The URI identifying the attestation predicate type, such as https://slsa.dev/provenance/v1 for SLSA provenance." .

slsa:attestationDigest a owl:DatatypeProperty ;
    rdfs:label "attestation digest" ;
    rdfs:comment "The cryptographic digest of the attested artifact" ;
    rdfs:domain slsa:ProvenanceAttestation ;
    rdfs:range xsd:string ;
    IAO:0000115 "A cryptographic digest (e.g., sha256:abc123) identifying the specific artifact this attestation covers." .

slsa:attestationTimestamp a owl:DatatypeProperty, owl:FunctionalProperty ;
    rdfs:label "attestation timestamp" ;
    rdfs:comment "When the attestation was created" ;
    rdfs:domain slsa:ProvenanceAttestation ;
    rdfs:range xsd:dateTime ;
    IAO:0000115 "The date and time when the provenance attestation was generated." .

slsa:signatureBundle a owl:DatatypeProperty ;
    rdfs:label "signature bundle" ;
    rdfs:comment "The DSSE or in-toto signature envelope for the attestation" ;
    rdfs:domain slsa:ProvenanceAttestation ;
    rdfs:range xsd:string ;
    IAO:0000115 "The serialized DSSE (Dead Simple Signing Envelope) or in-toto signature bundle containing the signed attestation." .

slsa:verificationStatus a owl:DatatypeProperty ;
    rdfs:label "verification status" ;
    rdfs:comment "Whether the attestation signature has been verified" ;
    rdfs:domain slsa:ProvenanceAttestation ;
    rdfs:range xsd:string ;
    IAO:0000115 "The verification status of the attestation signature: verified, unverified, or failed." .


# #################################################################
# #
# #    Datatype Properties — Builder
# #
# #################################################################

slsa:builderId a owl:DatatypeProperty, owl:FunctionalProperty ;
    rdfs:label "builder ID" ;
    rdfs:comment "The URI identifying the build platform" ;
    rdfs:domain slsa:Builder ;
    rdfs:range xsd:anyURI ;
    IAO:0000115 "A URI that uniquely identifies the build platform or service, such as https://github.com/actions/runner or https://koji.fedoraproject.org." .

slsa:builderVersion a owl:DatatypeProperty ;
    rdfs:label "builder version" ;
    rdfs:comment "The version of the build platform" ;
    rdfs:domain slsa:Builder ;
    rdfs:range xsd:string ;
    IAO:0000115 "The version identifier of the build platform or service used." .


# #################################################################
# #
# #    Datatype Properties — BuildEnvironment
# #
# #################################################################

slsa:buildImage a owl:DatatypeProperty ;
    rdfs:label "build image" ;
    rdfs:comment "The container image or base system used for the build" ;
    rdfs:domain slsa:BuildEnvironment ;
    rdfs:range xsd:string ;
    IAO:0000115 "The container image reference or base operating system image used to create the build environment." .

slsa:buildImageDigest a owl:DatatypeProperty ;
    rdfs:label "build image digest" ;
    rdfs:comment "The cryptographic digest of the build image" ;
    rdfs:domain slsa:BuildEnvironment ;
    rdfs:range xsd:string ;
    IAO:0000115 "A cryptographic digest uniquely identifying the exact build image version used." .

slsa:isEphemeral a owl:DatatypeProperty ;
    rdfs:label "is ephemeral" ;
    rdfs:comment "Whether the build environment was ephemeral (destroyed after use)" ;
    rdfs:domain slsa:BuildEnvironment ;
    rdfs:range xsd:boolean ;
    IAO:0000115 "Indicates whether the build environment was ephemeral — created fresh for the build and destroyed afterward, preventing cross-build contamination." .

slsa:isIsolated a owl:DatatypeProperty ;
    rdfs:label "is isolated" ;
    rdfs:comment "Whether the build environment was isolated from other tenants" ;
    rdfs:domain slsa:BuildEnvironment ;
    rdfs:range xsd:boolean ;
    IAO:0000115 "Indicates whether the build environment was isolated from other build tenants, preventing one build from influencing another." .


# #################################################################
# #
# #    Datatype Properties — SourceAttestation
# #
# #################################################################

slsa:sourceRepository a owl:DatatypeProperty ;
    rdfs:label "source repository" ;
    rdfs:comment "The URI of the source code repository" ;
    rdfs:domain slsa:SourceAttestation ;
    rdfs:range xsd:anyURI ;
    IAO:0000115 "The URI of the version control repository from which the source code was obtained." .

slsa:sourceRef a owl:DatatypeProperty ;
    rdfs:label "source ref" ;
    rdfs:comment "The VCS reference (branch, tag, or commit) of the source" ;
    rdfs:domain slsa:SourceAttestation ;
    rdfs:range xsd:string ;
    IAO:0000115 "The version control reference (branch name, tag, or commit hash) identifying the exact source code version used in the build." .

slsa:sourceDigest a owl:DatatypeProperty ;
    rdfs:label "source digest" ;
    rdfs:comment "The cryptographic digest of the source" ;
    rdfs:domain slsa:SourceAttestation ;
    rdfs:range xsd:string ;
    IAO:0000115 "A cryptographic digest of the source code tree used in the build, for integrity verification." .

slsa:twoPartyReviewed a owl:DatatypeProperty ;
    rdfs:label "two-party reviewed" ;
    rdfs:comment "Whether the source change was reviewed by a second party" ;
    rdfs:domain slsa:SourceAttestation ;
    rdfs:range xsd:boolean ;
    IAO:0000115 "Indicates whether the source code change underwent two-party review before being merged, as required for SLSA source requirements." .


# #################################################################
# #
# #    Object Properties
# #
# #################################################################

slsa:hasProvenance a owl:ObjectProperty ;
    rdfs:label "has provenance" ;
    rdfs:comment "Links a package to its SLSA provenance attestation" ;
    rdfs:domain pkg:Package ;
    rdfs:range slsa:ProvenanceAttestation ;
    IAO:0000115 "Associates a package with a SLSA provenance attestation documenting its build provenance." .

slsa:hasSourceAttestation a owl:ObjectProperty ;
    rdfs:label "has source attestation" ;
    rdfs:comment "Links a provenance attestation to its source attestation" ;
    rdfs:domain slsa:ProvenanceAttestation ;
    rdfs:range slsa:SourceAttestation ;
    IAO:0000115 "Associates a provenance attestation with the source attestation documenting the origin of the source code." .

slsa:attestsBuildLevel a owl:ObjectProperty ;
    rdfs:label "attests build level" ;
    rdfs:comment "Links a provenance attestation to its assessed SLSA build level" ;
    rdfs:domain slsa:ProvenanceAttestation ;
    rdfs:range slsa:BuildLevel ;
    IAO:0000115 "Associates a provenance attestation with the SLSA build level it attests to." .

slsa:attestsBuildActivity a owl:ObjectProperty ;
    rdfs:subPropertyOf prov:wasDerivedFrom ;
    rdfs:label "attests build activity" ;
    rdfs:comment "Links a provenance attestation to the build activity it documents" ;
    rdfs:domain slsa:ProvenanceAttestation ;
    rdfs:range pkg:BuildActivity ;
    IAO:0000115 "Associates a provenance attestation with the specific build activity whose provenance it documents." .

slsa:builtBy a owl:ObjectProperty ;
    rdfs:subPropertyOf prov:wasAssociatedWith ;
    rdfs:label "built by" ;
    rdfs:comment "Links a build activity to the builder that performed it" ;
    rdfs:domain pkg:BuildActivity ;
    rdfs:range slsa:Builder ;
    IAO:0000115 "Associates a build activity with the specific builder (CI/CD platform or build service) that executed it." .

slsa:usedBuildEnvironment a owl:ObjectProperty ;
    rdfs:subPropertyOf prov:used ;
    rdfs:label "used build environment" ;
    rdfs:comment "Links a build activity to the environment it ran in" ;
    rdfs:domain pkg:BuildActivity ;
    rdfs:range slsa:BuildEnvironment ;
    IAO:0000115 "Associates a build activity with the build environment (container, VM, or bare metal) in which it executed." .

slsa:hasSourceVcsRepository a owl:ObjectProperty ;
    rdfs:label "has source VCS repository" ;
    rdfs:comment "Links a source attestation to the VCS repository" ;
    rdfs:domain slsa:SourceAttestation ;
    rdfs:range vcs:Repository ;
    IAO:0000115 "Associates a source attestation with the version control repository from which the source was obtained." .

slsa:hasSourceCommit a owl:ObjectProperty ;
    rdfs:label "has source commit" ;
    rdfs:comment "Links a source attestation to the specific commit used" ;
    rdfs:domain slsa:SourceAttestation ;
    rdfs:range vcs:Commit ;
    IAO:0000115 "Associates a source attestation with the specific VCS commit that was used as the source for the build." .


# #################################################################
# #
# #    Cardinality Restrictions
# #
# #################################################################

slsa:ProvenanceAttestation rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty slsa:attestsBuildLevel ;
    owl:cardinality 1
] .

slsa:ProvenanceAttestation rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty slsa:attestationTimestamp ;
    owl:cardinality 1
] .

slsa:Builder rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty slsa:builderId ;
    owl:cardinality 1
] .
