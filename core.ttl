  rdfs:domain :PackagingActivity;
  <http://purl.obolibrary.org/obo/IAO_0000115> "Associates a packaging activity with the source code, files, or other materials it used as input.";
  rdfs:comment "Links a packaging activity to source materials it used";
  rdfs:label "used source" .

:wasBuiltBy a owl:ObjectProperty;
  rdfs:subPropertyOf prov:wasGeneratedBy;
  rdfs:domain :Package;
  rdfs:range :BuildActivity;
  <http://purl.obolibrary.org/obo/IAO_0000115> "Associates a package with the specific build activity that compiled and created it from source materials.";
  rdfs:comment "Links a package to the build activity that created it";
  rdfs:label "was built by" .

:wasPackagedBy a owl:ObjectProperty;
  rdfs:subPropertyOf prov:wasGeneratedBy;
  rdfs:domain :Package;
  rdfs:range :PackagingActivity;
  <http://purl.obolibrary.org/obo/IAO_0000115> "Associates a package with the packaging activity that assembled it into its final distributable form.";
  rdfs:comment "Links a package to the packaging activity that created it";
  rdfs:label "was packaged by" .

:wasPublishedBy a owl:ObjectProperty;
  rdfs:subPropertyOf prov:wasGeneratedBy;
  rdfs:domain :Package;
  rdfs:range :PublishingActivity;
  <http://purl.obolibrary.org/obo/IAO_0000115> "Associates a package with the publishing activity that made it available in a repository for distribution.";
  rdfs:comment "Links a package to the publishing activity that made it available";
  rdfs:label "was published by" .

:performedBy a owl:ObjectProperty;
  rdfs:subPropertyOf prov:wasAssociatedWith;
  rdfs:domain :PackagingActivity;
  rdfs:range prov:Agent;
  <http://purl.obolibrary.org/obo/IAO_0000115> "Associates a packaging activity with the agent (person, organization, or automated system) that performed it.";
  rdfs:comment "Links a packaging activity to the agent that performed it";
  rdfs:label "performed by" .

:builtFromSource a owl:ObjectProperty;
  rdfs:subPropertyOf prov:wasDerivedFrom;
  owl:inverseOf :producedBinary;
  rdfs:domain :BinaryPackage;
  rdfs:range :SourcePackage;
  <http://purl.obolibrary.org/obo/IAO_0000115> "Associates a binary package with the source package from which it was compiled, enabling grouping of related binary outputs.";
  rdfs:comment "Links a binary package to the source package it was built from";
  rdfs:label "built from source" .

:producedBinary a owl:ObjectProperty;
  rdfs:domain :SourcePackage;
  rdfs:range :BinaryPackage;
  <http://purl.obolibrary.org/obo/IAO_0000115> "Associates a source package with the binary packages produced by building it.";
  rdfs:comment "Links a source package to binary packages it produces";
  rdfs:label "produced binary" .

:hasUpstreamProject a owl:ObjectProperty;
  rdfs:domain :SourcePackage;
  rdfs:range :UpstreamProject;
  <http://purl.obolibrary.org/obo/IAO_0000115> "Associates a source package with the upstream open source project that it packages for distribution.";
  rdfs:comment "Links a source package to the upstream project it packages";
  rdfs:label "has upstream project" .

:hasDependency a owl:ObjectProperty;
  rdfs:domain :Package;
  rdfs:range :Dependency;
  <http://purl.obolibrary.org/obo/IAO_0000115> "Associates a package with a structured dependency that captures the target package, version constraints, and dependency type.";
  rdfs:comment "Links a package to a reified dependency relationship with version constraints";
  rdfs:label "has dependency" .

:dependencyTarget a owl:ObjectProperty;
  rdfs:domain :Dependency;
  rdfs:range :Package;
  <http://purl.obolibrary.org/obo/IAO_0000115> "Identifies the specific package that satisfies a dependency, linking the reified Dependency to its target Package.";
  rdfs:comment "The package that a dependency relationship targets";
  rdfs:label "dependency target" .

:hasRelease a owl:ObjectProperty;
  rdfs:domain :Distribution;
  rdfs:range :DistributionRelease;
  <http://purl.obolibrary.org/obo/IAO_0000115> "Associates a distribution with a specific versioned release, such as Debian 12 or Fedora 41.";
  rdfs:comment "Links a distribution to one of its releases";
  rdfs:label "has release" .

:partOfRelease a owl:ObjectProperty;
  rdfs:range :DistributionRelease;
  <http://purl.obolibrary.org/obo/IAO_0000115> "Associates packages, repositories, or other components with a specific versioned release of a distribution.";
  rdfs:comment "Links packages or repositories to a specific distribution release";
  rdfs:label "part of release" .

:hasAccount a owl:ObjectProperty;
  rdfs:domain :Contributor;
  rdfs:range :ContributorAccount;
  <http://purl.obolibrary.org/obo/IAO_0000115> "Associates a contributor with an account or identity on a specific platform such as GitHub, Debian, or Fedora, enabling cross-platform contributor identification.";
  rdfs:comment "Links a contributor to an identity on a specific platform";
  rdfs:label "has account" .

:installsFile a owl:ObjectProperty;
  rdfs:domain :BinaryPackage;
  rdfs:range :InstalledFile;
  <http://purl.obolibrary.org/obo/IAO_0000115> "Associates a binary package with a file it installs on the target filesystem.";
  rdfs:comment "Links a binary package to a file it installs on the system";
  rdfs:label "installs file" .

:supportedArchitecture a owl:ObjectProperty;
  rdfs:domain :SourcePackage;
  rdfs:range :Architecture;
  <http://purl.obolibrary.org/obo/IAO_0000115> "Associates a source package with an architecture it declares support for building, as declared in the source package control file.";
  rdfs:comment "An architecture that the source package can be built for";
  rdfs:label "supported architecture" .

:activeContributor a owl:DatatypeProperty;
  rdfs:domain :Contributor;
  rdfs:range xsd:boolean;
  <http://purl.obolibrary.org/obo/IAO_0000115> "Indicates whether a contributor is currently active in package development or maintenance.";
  rdfs:comment "Whether the contributor is currently active";
  rdfs:label "active contributor" .

:activityDuration a owl:DatatypeProperty;
  rdfs:domain prov:Activity;
  rdfs:range xsd:duration;
  <http://purl.obolibrary.org/obo/IAO_0000115> "The total time duration required to complete a packaging-related activity.";
  rdfs:comment "How long a packaging activity took to complete";
  rdfs:label "activity duration" .

:activityEndTime a owl:DatatypeProperty;
  rdfs:subPropertyOf prov:endedAtTime;
  rdfs:domain prov:Activity;
  rdfs:range xsd:dateTime;
  <http://purl.obolibrary.org/obo/IAO_0000115> "Records the date and time when a packaging-related activity was completed.";
  rdfs:comment "When a packaging activity completed";
  rdfs:label "activity end time" .

:activityLogOutput a owl:DatatypeProperty;
  rdfs:domain prov:Activity;
  rdfs:range xsd:string;
  <http://purl.obolibrary.org/obo/IAO_0000115> "The textual log output generated during the execution of a packaging activity, useful for debugging and auditing.";
  rdfs:comment "Log output generated during a packaging activity";
  rdfs:label "activity log output" .

:activityStartTime a owl:DatatypeProperty;
  rdfs:subPropertyOf prov:startedAtTime;
  rdfs:domain prov:Activity;
  rdfs:range xsd:dateTime;
  <http://purl.obolibrary.org/obo/IAO_0000115> "Records the date and time when a packaging-related activity was initiated.";
  rdfs:comment "When a packaging activity began";
  rdfs:label "activity start time" .

:checksum a owl:DatatypeProperty, owl:FunctionalProperty;
  rdfs:domain :Package;
  rdfs:range xsd:string;
  <http://purl.obolibrary.org/obo/IAO_0000115> "A cryptographic hash value computed from the package file contents, used to verify the integrity and authenticity of the package during download and installation.";
  rdfs:comment "A cryptographic hash of the package for integrity verification";
  rdfs:label "checksum" .

:checksumType a owl:DatatypeProperty, owl:FunctionalProperty;
  rdfs:domain :Package;
  rdfs:range xsd:string;
  <http://purl.obolibrary.org/obo/IAO_0000115> "The specific cryptographic hash algorithm used to compute the package checksum, such as MD5, SHA1, SHA256, or other hash functions.";
  rdfs:comment "The algorithm used to generate the checksum (e.g., MD5, SHA256)";
  rdfs:label "checksum type" .

:dependencyWeight a owl:DatatypeProperty;
  rdfs:domain :Dependency;
  rdfs:range xsd:float;
  <http://purl.obolibrary.org/obo/IAO_0000115> "Provides a numeric weight indicating the relative importance or strength of a dependency relationship.";
  rdfs:comment "Relative weight or importance of a dependency";
  rdfs:label "dependency weight" .

:description a owl:DatatypeProperty;
  rdfs:domain :Package;
  rdfs:range xsd:string;
  <http://purl.obolibrary.org/obo/IAO_0000115> "A textual explanation of the package's purpose, functionality, and features, intended to help users understand what the package provides.";
  rdfs:comment "A human-readable description of what the package does";
  rdfs:label "description" .

:downloadURL a owl:DatatypeProperty, owl:FunctionalProperty;
  rdfs:domain :Package;
  rdfs:range xsd:anyURI;
  <http://purl.obolibrary.org/obo/IAO_0000115> "The web address from which the package file or archive can be directly downloaded or accessed.";
  rdfs:comment "The URL from which the package can be downloaded";
  rdfs:label "download URL" .

:exitCode a owl:DatatypeProperty;
  rdfs:domain prov:Activity;
  rdfs:range xsd:int;
  <http://purl.obolibrary.org/obo/IAO_0000115> "The numeric exit code returned by a packaging activity, indicating success (typically 0) or failure (non-zero).";
  rdfs:comment "The exit code returned by a packaging activity";
  rdfs:label "exit code" .

:homepage a owl:DatatypeProperty, owl:FunctionalProperty;
  rdfs:range xsd:anyURI;
  <http://purl.obolibrary.org/obo/IAO_0000115> "The web address of the main website or homepage associated with the software package or its development project.";
  rdfs:comment "The homepage URL of the package or project";
  rdfs:label "homepage" .

:licenseName a owl:DatatypeProperty;
  rdfs:domain :Package;
  rdfs:range xsd:string;
  <http://purl.obolibrary.org/obo/IAO_0000115> "A string representation of the package's license, typically using SPDX license expression syntax. This is the direct collector output; for structured license objects, see hasLicense.";
  rdfs:comment "The SPDX license expression or license name string for the package";
  rdfs:label "license name" .

:upstreamPackageName a owl:DatatypeProperty;
  rdfs:domain :Package;
  rdfs:range xsd:string;
  <http://purl.obolibrary.org/obo/IAO_0000115> "The canonical name of the upstream software in its native package ecosystem, extracted from RPM provides entries like crate(foo) or python3dist(bar). Enables cross-ecosystem identity linking.";
  rdfs:comment "The name of the package in its upstream ecosystem (e.g., crate name, PyPI name)";
  rdfs:label "upstream package name" .

:upstreamEcosystem a owl:DatatypeProperty;
  rdfs:domain :Package;
  rdfs:range xsd:string;
  <http://purl.obolibrary.org/obo/IAO_0000115> "Identifies the upstream software ecosystem that the package originates from, such as cargo (Rust crates), pypi (Python packages), npm (Node.js), or gomod (Go modules).";
  rdfs:comment "The upstream package ecosystem (e.g., cargo, pypi, npm, gomod)";
  rdfs:label "upstream ecosystem" .

:installSize a owl:DatatypeProperty;
  rdfs:domain :Package;
  rdfs:range xsd:long;
  <http://purl.obolibrary.org/obo/IAO_0000115> "The amount of disk space, measured in bytes, that the package will occupy after being fully installed on the target system.";
  rdfs:comment "The disk space required when the package is installed";
  rdfs:label "install size" .

:isMetaPackage a owl:DatatypeProperty;
  rdfs:domain :Package;
  rdfs:range xsd:boolean;
  <http://purl.obolibrary.org/obo/IAO_0000115> "Indicates whether a package serves primarily as a meta-package that groups other packages through dependencies.";
  rdfs:comment "Indicates whether this is a meta package";
  rdfs:label "is meta package" .

:isVendorOriginated a owl:DatatypeProperty;
  rdfs:domain :Package;
  rdfs:range xsd:boolean;
  <http://purl.obolibrary.org/obo/IAO_0000115> "Indicates whether the upstream project was originated by the same organization that packages and distributes it, as opposed to being an independent community project.";
  rdfs:comment "Whether the upstream project was created by the packaging vendor";
  rdfs:label "is vendor originated" .

:isaSpecificCode a owl:DatatypeProperty;
  rdfs:domain :Package;
  rdfs:range xsd:boolean;
  <http://purl.obolibrary.org/obo/IAO_0000115> "Indicates whether the package contains processor-specific optimizations or machine code that is optimized for a particular instruction set architecture.";
  rdfs:comment "Indicates whether the package contains ISA-specific optimizations";
  rdfs:label "ISA-specific code" .

:maintainerSince a owl:DatatypeProperty;
  rdfs:domain :Maintainer;
  rdfs:range xsd:dateTime;
  <http://purl.obolibrary.org/obo/IAO_0000115> "Records when a maintainer began their maintenance responsibilities for a package.";
  rdfs:comment "Date when the maintainer started maintaining the package";
  rdfs:label "maintainer since" .

:packageName a owl:DatatypeProperty, owl:FunctionalProperty;
  rdfs:domain :Package;
  rdfs:range xsd:string;
  <http://purl.obolibrary.org/obo/IAO_0000115> "The unique identifier or name by which a software package is known within a package management system.";
  rdfs:comment "The name of a package";
  rdfs:label "package name" .

:packageSize a owl:DatatypeProperty;
  rdfs:domain :Package;
  rdfs:range xsd:long;
  <http://purl.obolibrary.org/obo/IAO_0000115> "The size of the package file or archive, measured in bytes, before installation or extraction.";
  rdfs:comment "The size of the package file";
  rdfs:label "package size" .

## upstreamProject DatatypeProperty removed in 0.4.0
## Superseded by hasUpstreamProject ObjectProperty (Package → UpstreamProject)

:versionConstraintOperator a owl:DatatypeProperty;
  rdfs:domain :Dependency;
  rdfs:range xsd:string;
  <http://purl.obolibrary.org/obo/IAO_0000115> "The comparison operator that defines how the version constraint should be evaluated, such as greater than, equal to, or less than.";
  rdfs:comment "The comparison operator used in a version constraint (e.g., '>=', '=', '<=')";
  rdfs:label "version constraint operator" .

:versionConstraintValue a owl:DatatypeProperty;
  rdfs:domain :Dependency;
  rdfs:range xsd:string;
  <http://purl.obolibrary.org/obo/IAO_0000115> "The specific version string that the constraint is compared against using the constraint operator.";
  rdfs:comment "The version value used in a version constraint";
  rdfs:label "version constraint value" .

:versionString a owl:DatatypeProperty, owl:FunctionalProperty;
  rdfs:domain :Version;
  rdfs:range xsd:string;
  <http://purl.obolibrary.org/obo/IAO_0000115> "A textual representation of a package version, typically following semantic versioning or other versioning schemes to indicate the release sequence and compatibility.";
  rdfs:comment "The version identifier of a package";
  rdfs:label "version string" .

:epoch a owl:DatatypeProperty;
  rdfs:domain :Version;
  rdfs:range xsd:integer;
  rdfs:comment "The epoch of the version, used in some systems to manage version comparison across different numbering schemes.";
  rdfs:label "epoch";
  <http://purl.obolibrary.org/obo/IAO_0000115> "A version component used to differentiate between incompatible versioning schemes or to correct mistakes in version ordering." .

:release a owl:DatatypeProperty;
  rdfs:domain :Version;
  rdfs:range xsd:string;
  rdfs:comment "The release number of the package, often indicating a packaging-specific update.";
  rdfs:label "release";
  <http://purl.obolibrary.org/obo/IAO_0000115> "An identifier for the packaging release of a specific version of the upstream software." .

:revision a owl:DatatypeProperty;
  rdfs:domain :Version;
  rdfs:range xsd:string;
  rdfs:comment "The revision of the package, often indicating a minor packaging update or a source control revision.";
  rdfs:label "revision";
  <http://purl.obolibrary.org/obo/IAO_0000115> "A version component that specifies a minor update or packaging-specific revision." .

:dependencyType a owl:DatatypeProperty;
  rdfs:domain :Dependency;
  rdfs:range xsd:string;
  <http://purl.obolibrary.org/obo/IAO_0000115> "Classifies the nature of a dependency relationship, such as runtime, build-time, recommended, suggested, or conflicting.";
  rdfs:comment "The type of dependency relationship (runtime, build, recommends, suggests, conflicts)";
  rdfs:label "dependency type" .

:releaseVersion a owl:DatatypeProperty;
  rdfs:domain :DistributionRelease;
  rdfs:range xsd:string;
  <http://purl.obolibrary.org/obo/IAO_0000115> "The version identifier of a distribution release, such as '12' for Debian 12 or '41' for Fedora 41.";
  rdfs:comment "The version number of the distribution release";
  rdfs:label "release version" .

:releaseCodename a owl:DatatypeProperty;
  rdfs:domain :DistributionRelease;
  rdfs:range xsd:string;
  <http://purl.obolibrary.org/obo/IAO_0000115> "The informal name or codename of a distribution release, such as 'bookworm' for Debian 12 or 'noble' for Ubuntu 24.04.";
  rdfs:comment "The codename of the distribution release";
  rdfs:label "release codename" .

:releaseDate a owl:DatatypeProperty;
  rdfs:domain :DistributionRelease;
  rdfs:range xsd:date;
  <http://purl.obolibrary.org/obo/IAO_0000115> "The date when a distribution release was officially published or made available.";
  rdfs:comment "The date the distribution release was published";
  rdfs:label "release date" .

:endOfLifeDate a owl:DatatypeProperty;
  rdfs:domain :DistributionRelease;
  rdfs:range xsd:date;
  <http://purl.obolibrary.org/obo/IAO_0000115> "The date when a distribution release ceases to receive security updates and support.";
  rdfs:comment "The date when the distribution release reaches end of life";
  rdfs:label "end of life date" .

:accountPlatform a owl:DatatypeProperty;
  rdfs:domain :ContributorAccount;
  rdfs:range xsd:string;
  <http://purl.obolibrary.org/obo/IAO_0000115> "Identifies the platform or service where a contributor account is registered, such as GitHub, Debian, Fedora, or GitLab.";
  rdfs:comment "The platform or service where the account exists";
  rdfs:label "account platform" .

:accountUsername a owl:DatatypeProperty;
  rdfs:domain :ContributorAccount;
  rdfs:range xsd:string;
  <http://purl.obolibrary.org/obo/IAO_0000115> "The username, login, or unique identifier of a contributor on a specific platform.";
  rdfs:comment "The username or identifier on the platform";
  rdfs:label "account username" .

:accountUrl a owl:DatatypeProperty;
  rdfs:domain :ContributorAccount;
  rdfs:range xsd:anyURI;
  <http://purl.obolibrary.org/obo/IAO_0000115> "The web URL of a contributor's profile page on a specific platform.";
  rdfs:comment "The URL of the contributor's profile on the platform";
  rdfs:label "account URL" .

:installedFilePath a owl:DatatypeProperty;
  rdfs:domain :InstalledFile;
  rdfs:range xsd:string;
  <http://purl.obolibrary.org/obo/IAO_0000115> "The absolute filesystem path where a file is installed on the target system, such as /usr/bin/gcc or /usr/lib/libssl.so.3.";
  rdfs:comment "The filesystem path where the file is installed";
  rdfs:label "installed file path" .

:projectName a owl:DatatypeProperty;
  rdfs:domain :UpstreamProject;
  rdfs:range xsd:string;
  <http://purl.obolibrary.org/obo/IAO_0000115> "The canonical or commonly used name of an upstream open source project, such as 'openssl' or 'gcc'.";
  rdfs:comment "The canonical name of the upstream project";
  rdfs:label "project name" .

:projectUrl a owl:DatatypeProperty;
  rdfs:domain :UpstreamProject;
  rdfs:range xsd:anyURI;
  <http://purl.obolibrary.org/obo/IAO_0000115> "The primary website or homepage URL for an upstream open source project.";
  rdfs:comment "The primary URL for the upstream project";
  rdfs:label "project URL" .

:ABI a owl:Class;
  rdfs:subClassOf owl:Thing;
  <http://purl.obolibrary.org/obo/IAO_0000115> "The low-level binary interface that defines calling conventions, data layouts, and system call interfaces for a specific platform.";
  rdfs:comment "The binary interface specification for a platform";
  rdfs:label "Application Binary Interface" .

:Architecture a owl:Class;
  rdfs:subClassOf owl:Thing;
  <http://purl.obolibrary.org/obo/IAO_0000115> "The specific hardware platform, instruction set, or system architecture for which a software package has been compiled or designed to run.";
  rdfs:comment "The hardware or software architecture for which a package is built";
  rdfs:label "Architecture" .

:BuildActivity a owl:Class;
  rdfs:subClassOf :PackagingActivity;
  <http://purl.obolibrary.org/obo/IAO_0000115> "An activity that compiles source code and creates executable binaries or libraries as part of the packaging process.";
  rdfs:comment "The process of compiling and building software from source";
  rdfs:label "Build Activity" .

:ContributionType a owl:Class;
  rdfs:subClassOf owl:Thing;
  <http://purl.obolibrary.org/obo/IAO_0000115> "Categorizes the nature of contributions made to a package, such as code, documentation, packaging, or security updates.";
  rdfs:comment "The type of contribution made to a package";
  rdfs:label "Contribution Type" .

:Contributor a owl:Class;
  rdfs:subClassOf prov:Agent;
  <http://purl.obolibrary.org/obo/IAO_0000115> "An individual or organization that contributes to the development, maintenance, or packaging of a software project.";
  rdfs:comment "A person or organization that contributes to a software package or project";
  rdfs:label "Contributor" .

:Dependency a owl:Class;
  rdfs:subClassOf owl:Thing;
  <http://purl.obolibrary.org/obo/IAO_0000115> "A requirement relationship between software packages where one package needs another package to be present and functional in order to operate correctly.";
  rdfs:comment "A relationship indicating that one package requires another package to function properly";
  rdfs:label "Dependency" .

:Distribution a owl:Class;
  rdfs:subClassOf owl:Thing;
  <http://purl.obolibrary.org/obo/IAO_0000115> "A complete operating system distribution that packages and distributes software using specific package management systems.";
  rdfs:comment "A specific Linux/Unix distribution";
  rdfs:label "Distribution" .

:Ecosystem a owl:Class;
  rdfs:subClassOf owl:Thing;
  <http://purl.obolibrary.org/obo/IAO_0000115> "A comprehensive package management ecosystem that may span multiple distributions, formats, and repositories, such as the Debian ecosystem including Ubuntu derivatives.";
  rdfs:comment "A broader ecosystem encompassing multiple distributions and package formats";
  rdfs:label "Package Ecosystem" .

:InstallationActivity a owl:Class;
  rdfs:subClassOf prov:Activity;
  <http://purl.obolibrary.org/obo/IAO_0000115> "An activity that deploys a package and its dependencies onto a target system, making the software available for use.";
  rdfs:comment "The process of installing a package on a system";
  rdfs:label "Installation Activity" .

:InstructionSetArchitecture a owl:Class;
  rdfs:subClassOf :Architecture;
  <http://purl.obolibrary.org/obo/IAO_0000115> "The processor instruction set architecture that defines the machine code interface, such as x86_64, ARM64, or RISC-V.";
  rdfs:comment "The specific instruction set architecture (ISA) for binary packages";
  rdfs:label "Instruction Set Architecture" .

:License a owl:Class;
  rdfs:subClassOf owl:Thing;
  <http://purl.obolibrary.org/obo/IAO_0000115> "A legal document or agreement that specifies the terms and conditions under which a software package may be used, modified, and distributed.";
  rdfs:comment "The legal license under which a package is distributed";
  rdfs:label "License" .

:Maintainer a owl:Class;
  rdfs:subClassOf :Contributor;
  <http://purl.obolibrary.org/obo/IAO_0000115> "An individual or organization that has responsibility for the ongoing development, maintenance, and support of a software package.";
  rdfs:comment "A person or organization responsible for maintaining a package";
  rdfs:label "Maintainer" .

:MaintainerRole a owl:Class;
  rdfs:subClassOf owl:Thing;
  <http://purl.obolibrary.org/obo/IAO_0000115> "Defines the specific responsibilities and authority level of a maintainer for a package, such as primary maintainer, co-maintainer, or sponsor.";
  rdfs:comment "The specific role a maintainer plays for a package";
  rdfs:label "Maintainer Role" .

:MetaPackage a owl:Class;
  rdfs:subClassOf :Package;
  <http://purl.obolibrary.org/obo/IAO_0000115> "A package that contains minimal or no files itself but serves to group related packages together through dependencies, commonly used for task-based installations.";
  rdfs:comment "A package that exists primarily to depend on other packages";
  rdfs:label "Meta Package" .

:Package a owl:Class;
  rdfs:subClassOf owl:Thing, prov:Entity, _:genid1, _:genid2, _:genid3, _:genid4, _:genid5,
    _:genid6, _:genid7;
  <http://purl.obolibrary.org/obo/IAO_0000115> "A discrete unit of software that can be installed, updated, or removed by a package management system, typically containing executable code, configuration files, documentation, and metadata.";
  rdfs:comment "A software package that can be installed, maintained, or distributed through a package management system";
  rdfs:label "Package" .

_:genid1 a owl:Restriction;
  owl:minCardinality "1"^^xsd:nonNegativeInteger;
  owl:onProperty :hasLicense .

_:genid2 a owl:Restriction;
  owl:minCardinality "1"^^xsd:nonNegativeInteger;
  owl:onProperty :hasVersion .

_:genid3 a owl:Restriction;
  owl:minCardinality "1"^^xsd:nonNegativeInteger;
  owl:onProperty :maintainedBy .

_:genid4 a owl:Restriction;
  owl:cardinality "1"^^xsd:nonNegativeInteger;
  owl:onProperty :packageName .

_:genid5 a owl:Restriction;
  owl:maxCardinality "1"^^xsd:nonNegativeInteger;
  owl:onProperty :checksum .

_:genid6 a owl:Restriction;
  owl:maxCardinality "1"^^xsd:nonNegativeInteger;
  owl:onProperty :downloadURL .

_:genid7 a owl:Restriction;
  owl:maxCardinality "1"^^xsd:nonNegativeInteger;
  owl:onProperty :homepage .

:PackageManager a owl:Class;
  rdfs:subClassOf owl:Thing;
  <http://purl.obolibrary.org/obo/IAO_0000115> "A software application or system that automates the process of installing, upgrading, configuring, and removing software packages, including dependency resolution and conflict management.";
  rdfs:comment "A software tool that manages the installation, updating, and removal of packages";
  rdfs:label "Package Manager" .

:PackageSet a owl:Class;
  rdfs:subClassOf owl:Thing;
  <http://purl.obolibrary.org/obo/IAO_0000115> "A named collection of packages within a distribution or product, used to define subsets such as base systems, application streams, or product-specific package sets.";
  rdfs:comment "A named subset of packages within a distribution or product";
  rdfs:label "Package Set" .

:PackagingActivity a owl:Class;
  rdfs:subClassOf prov:Activity;
  <http://purl.obolibrary.org/obo/IAO_0000115> "An activity that transforms source code, configuration files, and other materials into a distributable package format.";
  rdfs:comment "The process of creating a package from source materials";
  rdfs:label "Packaging Activity" .

:PublishingActivity a owl:Class;
  rdfs:subClassOf prov:Activity;
  <http://purl.obolibrary.org/obo/IAO_0000115> "An activity that uploads and makes a package available for distribution through a package repository.";
  rdfs:comment "The process of making a package available in a repository";
  rdfs:label "Publishing Activity" .

:Repository a owl:Class;
  rdfs:subClassOf owl:Thing, prov:Entity, _:genid8;
  <http://purl.obolibrary.org/obo/IAO_0000115> "A centralized storage location where software packages are hosted and made available for distribution, typically accessible via network protocols and managed by package management systems.";
  rdfs:comment "A storage location for packages, accessible through a package management system";
  rdfs:label "Repository" .

_:genid8 a owl:Restriction;
  owl:minCardinality "1"^^xsd:nonNegativeInteger;
  owl:onProperty :contains .

:TestActivity a owl:Class;
  rdfs:subClassOf prov:Activity;
  <http://purl.obolibrary.org/obo/IAO_0000115> "An activity that executes test suites to verify the functionality and quality of a software package.";
  rdfs:comment "The process of running tests on a package";
  rdfs:label "Test Activity" .

:Version a owl:Class;
  rdfs:subClassOf owl:Thing, _:genid9;
  <http://purl.obolibrary.org/obo/IAO_0000115> "A specific release or iteration of a software package, identified by a version string and representing a particular state of the package's development.";
  rdfs:comment "A specific version or release of a package";
  rdfs:label "Version" .

_:genid9 a owl:Restriction;
  owl:cardinality "1"^^xsd:nonNegativeInteger;
  owl:onProperty :versionString .

:VersionConstraint a owl:Class;
  rdfs:subClassOf owl:Thing;
  <http://purl.obolibrary.org/obo/IAO_0000115> "A structured specification that defines acceptable version ranges for package dependencies, including operators and target versions.";
  rdfs:comment "A structured representation of version constraints for dependencies";
  rdfs:label "Version Constraint" .

:VirtualPackage a owl:Class;
  rdfs:subClassOf :Package;
  <http://purl.obolibrary.org/obo/IAO_0000115> "An abstract package name that represents a functionality or interface that can be satisfied by multiple concrete package implementations.";
  rdfs:comment "A package name that represents a capability provided by one or more real packages";
  rdfs:label "Virtual Package" .

:SourcePackage a owl:Class;
  rdfs:subClassOf :Package;
  <http://purl.obolibrary.org/obo/IAO_0000115> "A source package containing the original source code, build scripts, and packaging metadata required to produce one or more binary packages for distribution.";
  rdfs:comment "A package containing source code that can be built into one or more binary packages";
  rdfs:label "Source Package" .

:BinaryPackage a owl:Class;
  rdfs:subClassOf :Package, _:genid10;
  <http://purl.obolibrary.org/obo/IAO_0000115> "A binary package containing compiled executables, libraries, or architecture-independent files, ready for installation on a target system.";
  rdfs:comment "A compiled, installable package produced from a source package";
  rdfs:label "Binary Package" .

_:genid10 a owl:Restriction;
  owl:cardinality "1"^^xsd:nonNegativeInteger;
  owl:onProperty :builtFromSource .

:UpstreamProject a owl:Class;
  rdfs:subClassOf owl:Thing, _:genid11;
  <http://purl.obolibrary.org/obo/IAO_0000115> "An upstream software project that serves as the origin for packages across multiple distributions, enabling cross-distribution analysis through a shared identity.";
  rdfs:comment "An upstream open source project that is packaged by one or more distributions";
  rdfs:label "Upstream Project" .

_:genid11 a owl:Restriction;
  owl:cardinality "1"^^xsd:nonNegativeInteger;
  owl:onProperty :projectName .

:DistributionRelease a owl:Class;
  rdfs:subClassOf owl:Thing;
  <http://purl.obolibrary.org/obo/IAO_0000115> "A specific versioned release of a Linux distribution, such as Debian 12 (bookworm) or Fedora 41, containing a defined set of packages.";
  rdfs:comment "A specific versioned release of a distribution";
  rdfs:label "Distribution Release" .

:ContributorAccount a owl:Class;
  rdfs:subClassOf owl:Thing;
  <http://purl.obolibrary.org/obo/IAO_0000115> "A platform-specific identity for a contributor, such as a GitHub username, Debian maintainer email, or Fedora Account System login, enabling cross-platform contributor identification.";
  rdfs:comment "An identity or account for a contributor on a specific platform";
  rdfs:label "Contributor Account" .

:InstalledFile a owl:Class;
  rdfs:subClassOf owl:Thing;
  <http://purl.obolibrary.org/obo/IAO_0000115> "A file that is installed on the target filesystem when a binary package is installed, including executables, libraries, configuration files, and documentation.";
  rdfs:comment "A file installed on the system by a binary package";
  rdfs:label "Installed File" .

###  https://purl.org/packagegraph/ontology/core#upstreamRepository
:upstreamRepository a owl:ObjectProperty ;
    owl:inverseOf <https://purl.org/packagegraph/ontology/vcs#hasPackage> ;
    rdfs:domain :PackageIdentity ;
    rdfs:range <https://purl.org/packagegraph/ontology/vcs#Repository> ;
    rdfs:label "upstream repository" ;
    rdfs:comment "The upstream VCS repository this package is built from. Derived from Homepage/URL when it points to a known forge, or from dist-git spec files." ;
    <http://purl.obolibrary.org/obo/IAO_0000115> "Associates a package identity with the canonical upstream source code repository. This is the primary cross-distribution identity anchor — packages from different distros that share the same upstream repository are the same software, regardless of package name." .

###  https://purl.org/packagegraph/ontology/core#packagingRepository
:packagingRepository a owl:ObjectProperty ;
    rdfs:domain :PackageIdentity ;
    rdfs:range <https://purl.org/packagegraph/ontology/vcs#Repository> ;
    rdfs:label "packaging repository" ;
    rdfs:comment "The distribution-specific packaging repository (e.g., Debian Salsa, Fedora dist-git). Contains packaging rules, patches, and build configuration." ;
    <http://purl.obolibrary.org/obo/IAO_0000115> "Associates a package identity with the distribution-specific repository that contains the packaging metadata (debian/ directory, spec files, patches). Distinct from the upstream repository — packaging repos are distro-specific while upstream repos are universal." .

###  https://purl.org/packagegraph/ontology/core#PackageIdentity
:PackageIdentity a owl:Class ;
    rdfs:subClassOf owl:Thing ;
    rdfs:label "Package Identity" ;
    rdfs:comment "The version-agnostic identity of a package within a distribution and architecture. Dependency targets point to this instead of versioned instances." ;
    <http://purl.obolibrary.org/obo/IAO_0000115> "A stable, version-independent identifier for a package name within a specific distribution, release, and architecture. BinaryPackage instances link to their identity via isVersionOf. Dependencies point to the identity, enabling direct name-based joins without URI parsing." .

###  https://purl.org/packagegraph/ontology/core#isVersionOf
:isVersionOf a owl:ObjectProperty ;
    owl:inverseOf :hasPackage ;
    rdfs:domain :BinaryPackage ;
    rdfs:range :PackageIdentity ;
    rdfs:label "is version of" ;
    rdfs:comment "Links a versioned binary package to its version-agnostic package identity." ;
    <http://purl.obolibrary.org/obo/IAO_0000115> "Associates a specific versioned binary package with the canonical package identity it belongs to. Enables queries that traverse from a versioned instance to all other versions of the same package." .

###  https://purl.org/packagegraph/ontology/core#hasPackage
:hasPackage a owl:ObjectProperty ;
    rdfs:domain :PackageIdentity ;
    rdfs:range :BinaryPackage ;
    rdfs:label "has package" ;
    rdfs:comment "Links a package identity to its versioned binary package instances." ;
    <http://purl.obolibrary.org/obo/IAO_0000115> "The inverse relationship of isVersionOf, linking a package identity to all versioned binary packages that belong to it. Enables efficient 'list all versions of package X' queries from the identity node." .

###  https://purl.org/packagegraph/ontology/core#DataSnapshot
:DataSnapshot a owl:Class ;
    rdfs:subClassOf <http://www.w3.org/ns/prov#Entity> ;
    rdfs:label "Data Snapshot" ;
    rdfs:comment "Metadata about a named graph — when it was collected, from what source, whether it is current." ;
    <http://purl.obolibrary.org/obo/IAO_0000115> "A record of a data collection or enrichment run, tracking the named graph URI, source identifier, timestamp, and currency status for graph lifecycle management." .

###  https://purl.org/packagegraph/ontology/core#snapshotSource
:snapshotSource a owl:DatatypeProperty ;
    rdfs:domain :DataSnapshot ;
    rdfs:range xsd:string ;
    rdfs:label "snapshot source" ;
    rdfs:comment "Identifier of the data source that produced this snapshot (e.g., 'pg-collect debian', 'enricher-osv')." ;
    <http://purl.obolibrary.org/obo/IAO_0000115> "A string identifying the tool and data source that produced this snapshot." .

###  https://purl.org/packagegraph/ontology/core#snapshotTimestamp
:snapshotTimestamp a owl:DatatypeProperty ;
    rdfs:domain :DataSnapshot ;
    rdfs:range xsd:dateTime ;
    rdfs:label "snapshot timestamp" ;
    rdfs:comment "When this data snapshot was created." ;
    <http://purl.obolibrary.org/obo/IAO_0000115> "The date and time when the data collection or enrichment run completed." .

###  https://purl.org/packagegraph/ontology/core#snapshotGraph
:snapshotGraph a owl:DatatypeProperty ;
    rdfs:domain :DataSnapshot ;
    rdfs:range xsd:anyURI ;
    rdfs:label "snapshot graph" ;
    rdfs:comment "The named graph URI this snapshot was loaded into." ;
    <http://purl.obolibrary.org/obo/IAO_0000115> "The URI of the named graph in Fuseki that contains this snapshot's data." .

###  https://purl.org/packagegraph/ontology/core#isCurrent
:isCurrent a owl:DatatypeProperty, owl:FunctionalProperty ;
    rdfs:domain :DataSnapshot ;
    rdfs:range xsd:boolean ;
    rdfs:label "is current" ;
    rdfs:comment "Whether this snapshot represents the current active data for its source." ;
    <http://purl.obolibrary.org/obo/IAO_0000115> "A boolean flag indicating whether this snapshot is the most recent for its data source. Used for tiered storage lifecycle management." .
