# Hackage Package Ontology
@prefix hackage: <https://purl.org/packagegraph/ontology/hackage#> .
@prefix pkg: <https://purl.org/packagegraph/ontology/core#> .

@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix IAO: <http://purl.obolibrary.org/obo/IAO_> .

<https://purl.org/packagegraph/ontology/hackage#> a owl:Ontology ;
    rdfs:label "Hackage Package Ontology" ;
    rdfs:comment "Ontology for representing Hackage packages and the Haskell ecosystem" ;
    dcterms:abstract "Models Hackage packages including Cabal metadata, GHC version compatibility, categories, stability levels, and build-depends relationships. Instances are dual-typed as both pkg:Package and hackage:HackagePackage." ;
    dcterms:created "2026-04-14"^^xsd:date ;
    dcterms:license <https://creativecommons.org/publicdomain/zero/1.0/> ;
    owl:versionInfo "0.5.1" ;
    owl:imports <core.ttl> .

# Classes

hackage:HackagePackage a owl:Class ;
    rdfs:subClassOf pkg:Package ;
    rdfs:label "Hackage Package" ;
    rdfs:comment "A package published to Hackage" ;
    IAO:0000115 "A Haskell library or application distributed through Hackage, described by a .cabal file." .

hackage:CabalFile a owl:Class ;
    rdfs:label "Cabal File" ;
    rdfs:comment "A Cabal package description file" ;
    IAO:0000115 "A .cabal file describing a Haskell package's metadata, dependencies, and build configuration." .

hackage:HackageRepository a owl:Class ;
    rdfs:subClassOf pkg:Repository ;
    rdfs:label "Hackage Repository" ;
    rdfs:comment "The Hackage package repository" ;
    IAO:0000115 "The Hackage repository serving Haskell packages at hackage.haskell.org." .

# Datatype Properties

hackage:category a owl:DatatypeProperty ;
    rdfs:label "category" ;
    rdfs:domain hackage:HackagePackage ;
    rdfs:range xsd:string ;
    IAO:0000115 "Package category from the Cabal file (e.g., 'Web', 'Data', 'Network')." .

hackage:stability a owl:DatatypeProperty ;
    rdfs:label "stability" ;
    rdfs:domain hackage:HackagePackage ;
    rdfs:range xsd:string ;
    IAO:0000115 "Package stability level (e.g., 'stable', 'experimental', 'provisional')." .

hackage:synopsis a owl:DatatypeProperty ;
    rdfs:label "synopsis" ;
    rdfs:domain hackage:HackagePackage ;
    rdfs:range xsd:string ;
    IAO:0000115 "One-line package description from the Cabal synopsis field." .

hackage:testedWith a owl:DatatypeProperty ;
    rdfs:label "tested with" ;
    rdfs:domain hackage:HackagePackage ;
    rdfs:range xsd:string ;
    IAO:0000115 "GHC versions this package has been tested with (e.g., 'GHC ==9.2.8, GHC ==9.4.8')." .

hackage:bugReports a owl:DatatypeProperty ;
    rdfs:label "bug reports" ;
    rdfs:domain hackage:HackagePackage ;
    rdfs:range xsd:anyURI ;
    IAO:0000115 "URL for reporting bugs." .

hackage:maintainer a owl:DatatypeProperty ;
    rdfs:label "maintainer" ;
    rdfs:domain hackage:HackagePackage ;
    rdfs:range xsd:string ;
    IAO:0000115 "Package maintainer name and email." .

# Object Properties

hackage:buildDepends a owl:ObjectProperty ;
    rdfs:subPropertyOf pkg:dependsOn ;
    rdfs:label "build depends" ;
    rdfs:domain hackage:HackagePackage ;
    rdfs:range hackage:HackagePackage ;
    IAO:0000115 "A build-depends dependency required to compile the package." .

hackage:publishedTo a owl:ObjectProperty ;
    rdfs:label "published to" ;
    rdfs:domain hackage:HackagePackage ;
    rdfs:range hackage:HackageRepository ;
    IAO:0000115 "Associates a package with the Hackage repository." .
