# RubyGems Package Ontology
@prefix rubygems: <https://purl.org/packagegraph/ontology/rubygems#> .
@prefix pkg: <https://purl.org/packagegraph/ontology/core#> .

@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix IAO: <http://purl.obolibrary.org/obo/IAO_> .

<https://purl.org/packagegraph/ontology/rubygems#> a owl:Ontology ;
    rdfs:label "RubyGems Package Ontology" ;
    rdfs:comment "Ontology for representing RubyGems packages and the Ruby ecosystem" ;
    dcterms:abstract "Models RubyGems registry packages including gem platforms, Ruby version requirements, prerelease versions, and gem dependencies. Instances are dual-typed as both pkg:Package and rubygems:Gem." ;
    dcterms:created "2026-04-14"^^xsd:date ;
    dcterms:license <https://creativecommons.org/publicdomain/zero/1.0/> ;
    owl:versionInfo "0.5.1" ;
    owl:imports <core.ttl> .

# Classes

rubygems:Gem a owl:Class ;
    rdfs:subClassOf pkg:Package ;
    rdfs:label "Gem" ;
    rdfs:comment "A package published to a RubyGems registry" ;
    IAO:0000115 "A Ruby library or application distributed through the RubyGems package manager, described by a gemspec file." .

rubygems:Platform a owl:Class ;
    rdfs:label "Platform" ;
    rdfs:comment "A target platform for a gem (e.g., ruby, java, x86_64-linux)" ;
    IAO:0000115 "A platform identifier indicating the Ruby runtime or operating system a gem is compatible with, such as 'ruby' for MRI, 'java' for JRuby, or 'x86_64-linux' for native extensions." .

rubygems:GemRequirement a owl:Class ;
    rdfs:label "Gem Requirement" ;
    rdfs:comment "A version requirement specification for a gem dependency" ;
    IAO:0000115 "A version constraint expression using RubyGems requirement syntax (e.g., '~> 2.0', '>= 1.5.0', '!= 3.0.0')." .

rubygems:RubyGemsRegistry a owl:Class ;
    rdfs:subClassOf pkg:Repository ;
    rdfs:label "RubyGems Registry" ;
    rdfs:comment "A RubyGems package registry (rubygems.org or private)" ;
    IAO:0000115 "A package registry serving RubyGems, such as the public rubygems.org registry or a private gem server." .

# Datatype Properties

rubygems:platform a owl:DatatypeProperty ;
    rdfs:label "platform" ;
    rdfs:domain rubygems:Gem ;
    rdfs:range xsd:string ;
    IAO:0000115 "The platform identifier for this gem (e.g., 'ruby', 'java', 'x86_64-linux')." .

rubygems:requiredRubyVersion a owl:DatatypeProperty ;
    rdfs:label "required ruby version" ;
    rdfs:domain rubygems:Gem ;
    rdfs:range xsd:string ;
    IAO:0000115 "The Ruby version requirement for this gem, expressed as a RubyGems version constraint (e.g., '>= 2.7.0', '~> 3.0')." .

rubygems:requiredRubygemsVersion a owl:DatatypeProperty ;
    rdfs:label "required rubygems version" ;
    rdfs:domain rubygems:Gem ;
    rdfs:range xsd:string ;
    IAO:0000115 "The RubyGems version requirement for installing this gem, expressed as a version constraint." .

rubygems:sha256 a owl:DatatypeProperty ;
    rdfs:label "SHA-256 checksum" ;
    rdfs:domain rubygems:Gem ;
    rdfs:range xsd:string ;
    IAO:0000115 "The SHA-256 hash of the gem file, used for integrity verification during installation." .

rubygems:authors a owl:DatatypeProperty ;
    rdfs:label "authors" ;
    rdfs:domain rubygems:Gem ;
    rdfs:range xsd:string ;
    IAO:0000115 "Comma-separated list of gem authors as specified in the gemspec." .

rubygems:downloads a owl:DatatypeProperty ;
    rdfs:label "downloads" ;
    rdfs:domain rubygems:Gem ;
    rdfs:range xsd:integer ;
    IAO:0000115 "Total number of downloads for this specific gem version." .

rubygems:yanked a owl:DatatypeProperty ;
    rdfs:label "yanked" ;
    rdfs:domain rubygems:Gem ;
    rdfs:range xsd:boolean ;
    IAO:0000115 "Whether this gem version has been yanked (removed from general availability but still installable if explicitly referenced)." .

rubygems:prerelease a owl:DatatypeProperty ;
    rdfs:label "prerelease" ;
    rdfs:domain rubygems:Gem ;
    rdfs:range xsd:boolean ;
    IAO:0000115 "Whether this is a prerelease version (e.g., alpha, beta, rc)." .

rubygems:gemUri a owl:DatatypeProperty ;
    rdfs:label "gem URI" ;
    rdfs:domain rubygems:Gem ;
    rdfs:range xsd:anyURI ;
    IAO:0000115 "The download URI for the gem file (.gem)." .

rubygems:projectUri a owl:DatatypeProperty ;
    rdfs:label "project URI" ;
    rdfs:domain rubygems:Gem ;
    rdfs:range xsd:anyURI ;
    IAO:0000115 "The project homepage or source repository URI specified in the gemspec." .

rubygems:sourceCodeUri a owl:DatatypeProperty ;
    rdfs:label "source code URI" ;
    rdfs:domain rubygems:Gem ;
    rdfs:range xsd:anyURI ;
    IAO:0000115 "The source code repository URI (often GitHub)." .

# Object Properties

rubygems:requirementOperator a owl:DatatypeProperty ;
    rdfs:label "requirement operator" ;
    rdfs:domain rubygems:GemRequirement ;
    rdfs:range xsd:string ;
    IAO:0000115 "The version constraint operator (e.g., '~>', '>=', '!=', '=')." .

rubygems:requirementVersion a owl:DatatypeProperty ;
    rdfs:label "requirement version" ;
    rdfs:domain rubygems:GemRequirement ;
    rdfs:range xsd:string ;
    IAO:0000115 "The version number in the requirement constraint." .

rubygems:runtimeDependency a owl:ObjectProperty ;
    rdfs:subPropertyOf pkg:dependsOn ;
    rdfs:label "runtime dependency" ;
    rdfs:domain rubygems:Gem ;
    rdfs:range rubygems:Gem ;
    IAO:0000115 "A runtime dependency required when the gem is used." .

rubygems:developmentDependency a owl:ObjectProperty ;
    rdfs:subPropertyOf pkg:dependsOn ;
    rdfs:label "development dependency" ;
    rdfs:domain rubygems:Gem ;
    rdfs:range rubygems:Gem ;
    IAO:0000115 "A development dependency required only for gem development and testing, not for runtime use." .

rubygems:publishedTo a owl:ObjectProperty ;
    rdfs:label "published to" ;
    rdfs:domain rubygems:Gem ;
    rdfs:range rubygems:RubyGemsRegistry ;
    IAO:0000115 "Associates a gem with the RubyGems registry it was published to." .
