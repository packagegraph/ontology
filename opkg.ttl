# OpenWRT Package Feed Ontology
@prefix opkg: <https://purl.org/packagegraph/ontology/opkg#> .
@prefix pkg: <https://purl.org/packagegraph/ontology/core#> .

@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix IAO: <http://purl.obolibrary.org/obo/IAO_> .

<https://purl.org/packagegraph/ontology/opkg#> a owl:Ontology ;
    rdfs:label "OpenWRT Package Ontology" ;
    rdfs:comment "Ontology for representing OpenWRT packages and feed repositories" ;
    dcterms:abstract "Models the OpenWRT/LEDE embedded Linux distribution for routers and IoT devices, including package feeds (packages, luci, routing, telephony), Makefile-based package definitions, kernel modules (kmod-*), UCI configuration integration, targets/subtargets for hardware, and opkg package format. OpenWRT Makefiles can define multiple sub-packages from a single source." ;
    dcterms:created "2026-04-17"^^xsd:date ;
    dcterms:license <https://creativecommons.org/publicdomain/zero/1.0/> ;
    owl:versionInfo "0.6.0" ;
    owl:imports <core.ttl> .

# =============================================================================
# Classes
# =============================================================================

opkg:OpkgPackage a owl:Class ;
    rdfs:subClassOf pkg:Package ;
    rdfs:label "OpenWRT Package" ;
    rdfs:comment "An OpenWRT package from a feed repository" ;
    IAO:0000115 "A package defined in an OpenWRT feed repository via a Makefile, compiled as an opkg (.ipk) binary for router/IoT targets. A single Makefile can define multiple sub-packages via separate 'define Package/<name>' blocks, all sharing the same upstream source." .

opkg:Feed a owl:Class ;
    rdfs:subClassOf pkg:Repository ;
    rdfs:label "Package Feed" ;
    rdfs:comment "An OpenWRT package feed repository" ;
    IAO:0000115 "A package feed repository containing OpenWRT packages, organized by category (e.g., packages, luci, routing, telephony). Feeds are git repositories that are compiled into an opkg-compatible package index." .

opkg:KernelModule a owl:Class ;
    rdfs:subClassOf opkg:OpkgPackage ;
    rdfs:label "Kernel Module Package" ;
    rdfs:comment "An OpenWRT kernel module package (kmod-*)" ;
    IAO:0000115 "A package providing a Linux kernel module (kmod-* prefix), with autoload configuration and dependency tracking. Kernel modules are version-locked to the running kernel and rebuilt on each kernel update." .

opkg:UciConfig a owl:Class ;
    rdfs:subClassOf owl:Thing ;
    rdfs:label "UCI Configuration" ;
    rdfs:comment "A Unified Configuration Interface definition" ;
    IAO:0000115 "A UCI (Unified Configuration Interface) configuration section integrated with this package, allowing web-based (LuCI) or CLI (uci) management. UCI provides a uniform configuration abstraction across OpenWRT packages." .

opkg:Target a owl:Class ;
    rdfs:subClassOf pkg:Architecture ;
    rdfs:label "Target" ;
    rdfs:comment "An OpenWRT target platform" ;
    IAO:0000115 "A target platform defining the SoC family and board support (e.g., 'ath79' for Atheros/Qualcomm AR7xxx/AR9xxx, 'ramips' for MediaTek/Ralink). Targets contain subtargets for specific chip variants." .

opkg:Subtarget a owl:Class ;
    rdfs:subClassOf opkg:Target ;
    rdfs:label "Subtarget" ;
    rdfs:comment "An OpenWRT subtarget within a target platform" ;
    IAO:0000115 "A subtarget within a target platform, specifying the exact SoC variant (e.g., 'generic', 'nand', 'tiny'). Subtargets determine kernel configuration and available device profiles." .

opkg:DeviceProfile a owl:Class ;
    rdfs:subClassOf prov:Entity ;
    rdfs:label "Device Profile" ;
    rdfs:comment "An OpenWRT device-specific build profile" ;
    IAO:0000115 "A device-specific build profile defining the hardware model (e.g., 'linksys_wrt1900acs'), default packages, flash layout, and device tree. Device profiles are the most specific hardware target." .

# =============================================================================
# Datatype Properties
# =============================================================================

opkg:feed a owl:DatatypeProperty ;
    rdfs:label "feed" ;
    rdfs:domain opkg:OpkgPackage ;
    rdfs:range xsd:string ;
    IAO:0000115 "The feed containing this package (e.g., 'packages', 'luci', 'routing', 'telephony')." .

opkg:category a owl:DatatypeProperty ;
    rdfs:label "category" ;
    rdfs:domain opkg:OpkgPackage ;
    rdfs:range xsd:string ;
    IAO:0000115 "The package category within the feed (e.g., 'Network', 'Utilities', 'Libraries', 'Administration'). Uppercase first letter per OpenWRT convention." .

opkg:section a owl:DatatypeProperty ;
    rdfs:label "section" ;
    rdfs:domain opkg:OpkgPackage ;
    rdfs:range xsd:string ;
    IAO:0000115 "The package section (lowercase categorization used in some feed definitions, e.g., 'net', 'utils', 'libs')." .

opkg:title a owl:DatatypeProperty ;
    rdfs:label "title" ;
    rdfs:domain opkg:OpkgPackage ;
    rdfs:range xsd:string ;
    IAO:0000115 "The package title from the 'define Package/<name>' block — a short one-line description for package managers." .

opkg:pkgRelease a owl:DatatypeProperty ;
    rdfs:label "PKG_RELEASE" ;
    rdfs:domain opkg:OpkgPackage ;
    rdfs:range xsd:string ;
    IAO:0000115 "The package release number (PKG_RELEASE variable), incremented when the Makefile changes but upstream version doesn't." .

opkg:sourceUrl a owl:DatatypeProperty ;
    rdfs:label "source URL" ;
    rdfs:domain opkg:OpkgPackage ;
    rdfs:range xsd:string ;
    IAO:0000115 "The source download URL from PKG_SOURCE_URL variable. Identifies the upstream source origin." .

opkg:sourceProto a owl:DatatypeProperty ;
    rdfs:label "source protocol" ;
    rdfs:domain opkg:OpkgPackage ;
    rdfs:range xsd:string ;
    IAO:0000115 "The source fetch protocol from PKG_SOURCE_PROTO variable (e.g., 'git', 'svn'). When absent, HTTP/FTP download is assumed." .

opkg:sourceMirrorHash a owl:DatatypeProperty ;
    rdfs:label "source mirror hash" ;
    rdfs:domain opkg:OpkgPackage ;
    rdfs:range xsd:string ;
    IAO:0000115 "The PKG_MIRROR_HASH or PKG_HASH value used to verify the source archive integrity." .

opkg:maintainer a owl:DatatypeProperty ;
    rdfs:label "maintainer" ;
    rdfs:domain opkg:OpkgPackage ;
    rdfs:range xsd:string ;
    IAO:0000115 "The package maintainer from PKG_MAINTAINER variable (name and email)." .

opkg:url a owl:DatatypeProperty ;
    rdfs:label "URL" ;
    rdfs:domain opkg:OpkgPackage ;
    rdfs:range xsd:anyURI ;
    IAO:0000115 "The upstream project URL from the URL field in the 'define Package' block." .

opkg:autoload a owl:DatatypeProperty ;
    rdfs:label "autoload" ;
    rdfs:domain opkg:KernelModule ;
    rdfs:range xsd:string ;
    IAO:0000115 "Kernel module autoload configuration (which modules to load on boot and in what order)." .

opkg:menu a owl:DatatypeProperty ;
    rdfs:label "menu" ;
    rdfs:domain opkg:OpkgPackage ;
    rdfs:range xsd:string ;
    IAO:0000115 "The Kconfig menu path where this package appears in menuconfig." .

opkg:defaultEnabled a owl:DatatypeProperty ;
    rdfs:label "default enabled" ;
    rdfs:domain opkg:OpkgPackage ;
    rdfs:range xsd:boolean ;
    IAO:0000115 "Whether the package is selected by default in the build configuration." .

opkg:hidden a owl:DatatypeProperty ;
    rdfs:label "hidden" ;
    rdfs:domain opkg:OpkgPackage ;
    rdfs:range xsd:boolean ;
    IAO:0000115 "Whether the package is hidden from menuconfig (selected only as a dependency, never directly by the user)." .

opkg:targetName a owl:DatatypeProperty ;
    rdfs:label "target name" ;
    rdfs:domain opkg:Target ;
    rdfs:range xsd:string ;
    IAO:0000115 "The target platform identifier (e.g., 'ath79', 'ramips', 'x86')." .

opkg:subtargetName a owl:DatatypeProperty ;
    rdfs:label "subtarget name" ;
    rdfs:domain opkg:Subtarget ;
    rdfs:range xsd:string ;
    IAO:0000115 "The subtarget identifier within a target (e.g., 'generic', 'nand', 'tiny')." .

opkg:profileName a owl:DatatypeProperty ;
    rdfs:label "profile name" ;
    rdfs:domain opkg:DeviceProfile ;
    rdfs:range xsd:string ;
    IAO:0000115 "The device profile identifier (e.g., 'linksys_wrt1900acs', 'tplink_archer-c7-v5')." .

opkg:profileDevice a owl:DatatypeProperty ;
    rdfs:label "profile device" ;
    rdfs:domain opkg:DeviceProfile ;
    rdfs:range xsd:string ;
    IAO:0000115 "The human-readable device name for this profile." .

opkg:flashSize a owl:DatatypeProperty ;
    rdfs:label "flash size" ;
    rdfs:domain opkg:DeviceProfile ;
    rdfs:range xsd:integer ;
    IAO:0000115 "The flash storage size in bytes for this device. Critical constraint for image size — packages must fit within this limit." .

opkg:ramSize a owl:DatatypeProperty ;
    rdfs:label "RAM size" ;
    rdfs:domain opkg:DeviceProfile ;
    rdfs:range xsd:integer ;
    IAO:0000115 "The RAM size in bytes for this device. Constrains which packages can run simultaneously." .

# =============================================================================
# Object Properties
# =============================================================================

opkg:inFeed a owl:ObjectProperty ;
    rdfs:label "in feed" ;
    rdfs:domain opkg:OpkgPackage ;
    rdfs:range opkg:Feed ;
    IAO:0000115 "Associates a package with the feed repository it belongs to." .

opkg:hasUciConfig a owl:ObjectProperty ;
    rdfs:label "has UCI config" ;
    rdfs:domain opkg:OpkgPackage ;
    rdfs:range opkg:UciConfig ;
    IAO:0000115 "Associates a package with UCI configuration sections it provides. Enables queries like 'what packages are configurable via LuCI'." .

opkg:providesKmod a owl:ObjectProperty ;
    rdfs:label "provides kernel module" ;
    rdfs:domain opkg:OpkgPackage ;
    rdfs:range opkg:KernelModule ;
    IAO:0000115 "Associates a package with kernel modules it provides." .

opkg:forTarget a owl:ObjectProperty ;
    rdfs:label "for target" ;
    rdfs:domain opkg:OpkgPackage ;
    rdfs:range opkg:Target ;
    IAO:0000115 "Associates a package with the target platform(s) it is available for." .

opkg:hasSubtarget a owl:ObjectProperty ;
    rdfs:label "has subtarget" ;
    rdfs:domain opkg:Target ;
    rdfs:range opkg:Subtarget ;
    IAO:0000115 "Associates a target with its subtargets." .

opkg:hasProfile a owl:ObjectProperty ;
    rdfs:label "has profile" ;
    rdfs:domain opkg:Subtarget ;
    rdfs:range opkg:DeviceProfile ;
    IAO:0000115 "Associates a subtarget with its device profiles." .

opkg:defaultPackages a owl:ObjectProperty ;
    rdfs:label "default packages" ;
    rdfs:domain opkg:DeviceProfile ;
    rdfs:range opkg:OpkgPackage ;
    IAO:0000115 "Associates a device profile with packages included by default. Defines the baseline package set for a device." .

opkg:parentPackage a owl:ObjectProperty ;
    rdfs:label "parent package" ;
    rdfs:domain opkg:OpkgPackage ;
    rdfs:range opkg:OpkgPackage ;
    IAO:0000115 "Links a sub-package to the primary package defined in the same Makefile. Multiple 'define Package/<name>' blocks in one Makefile share upstream source but produce separate .ipk binaries." .
