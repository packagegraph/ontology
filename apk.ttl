# Alpine APK Package Ontology
@prefix apk: <https://purl.org/packagegraph/ontology/apk#> .
@prefix pkg: <https://purl.org/packagegraph/ontology/core#> .

@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix IAO: <http://purl.obolibrary.org/obo/IAO_> .

<https://purl.org/packagegraph/ontology/apk#> a owl:Ontology ;
    rdfs:label "Alpine APK Package Ontology" ;
    rdfs:comment "Ontology for representing Alpine Linux packages and the apk-tools ecosystem" ;
    dcterms:abstract "Models Alpine Linux packages including the APKINDEX format, abuild build system, virtual packages, install-if triggers, and the musl libc distinction. Alpine is the foundation of most container base images." ;
    dcterms:created "2026-04-14"^^xsd:date ;
    dcterms:license <https://creativecommons.org/publicdomain/zero/1.0/> ;
    owl:versionInfo "0.5.0" ;
    owl:imports <core.ttl> .

# Classes

apk:ApkPackage a owl:Class ;
    rdfs:subClassOf pkg:BinaryPackage ;
    rdfs:label "Alpine Package" ;
    rdfs:comment "An APK package for Alpine Linux" ;
    IAO:0000115 "A binary package in Alpine APK format, managed by apk-tools, typically built against musl libc." .

apk:ApkRepository a owl:Class ;
    rdfs:subClassOf pkg:Repository ;
    rdfs:label "APK Repository" ;
    rdfs:comment "An Alpine package repository" ;
    IAO:0000115 "A repository containing Alpine packages indexed by APKINDEX.tar.gz, organized by branch and repository name (main, community, testing)." .

apk:AbuildScript a owl:Class ;
    rdfs:label "APKBUILD Script" ;
    rdfs:comment "An abuild build script (APKBUILD)" ;
    IAO:0000115 "A shell script defining how to build an Alpine package from source, located in the aports repository." .

apk:ApkBranch a owl:Class ;
    rdfs:label "Alpine Branch" ;
    rdfs:comment "An Alpine release branch (e.g., v3.20, edge)" ;
    IAO:0000115 "An Alpine Linux release branch, either a stable release (v3.20, v3.19) or the rolling edge branch." .

# Datatype Properties

apk:apkOrigin a owl:DatatypeProperty ;
    rdfs:label "origin" ;
    rdfs:domain apk:ApkPackage ;
    rdfs:range xsd:string ;
    IAO:0000115 "The origin package name — the APKBUILD that produced this package (one APKBUILD can produce multiple subpackages)." .

apk:buildDate a owl:DatatypeProperty ;
    rdfs:label "build date" ;
    rdfs:domain apk:ApkPackage ;
    rdfs:range xsd:long ;
    IAO:0000115 "Unix timestamp of when the package was built." .

apk:apkChecksum a owl:DatatypeProperty ;
    rdfs:label "APK checksum" ;
    rdfs:domain apk:ApkPackage ;
    rdfs:range xsd:string ;
    IAO:0000115 "The content hash of the package (Q1 prefix = SHA-1 of the control+data portion)." .

apk:installIf a owl:DatatypeProperty ;
    rdfs:label "install if" ;
    rdfs:domain apk:ApkPackage ;
    rdfs:range xsd:string ;
    IAO:0000115 "Conditional install trigger — this package is automatically installed when all listed packages are present." .

apk:triggers a owl:DatatypeProperty ;
    rdfs:label "triggers" ;
    rdfs:domain apk:ApkPackage ;
    rdfs:range xsd:string ;
    IAO:0000115 "Filesystem paths that trigger this package's trigger script when modified by another package." .

apk:providerPriority a owl:DatatypeProperty ;
    rdfs:label "provider priority" ;
    rdfs:domain apk:ApkPackage ;
    rdfs:range xsd:integer ;
    IAO:0000115 "Priority when multiple packages provide the same virtual, higher value wins." .

apk:repoName a owl:DatatypeProperty ;
    rdfs:label "repository name" ;
    rdfs:domain apk:ApkRepository ;
    rdfs:range xsd:string ;
    IAO:0000115 "The repository name within the branch (main, community, or testing)." .

apk:branchName a owl:DatatypeProperty ;
    rdfs:label "branch name" ;
    rdfs:domain apk:ApkBranch ;
    rdfs:range xsd:string ;
    IAO:0000115 "The Alpine branch identifier (e.g., 'v3.20', 'edge')." .

apk:usesMusl a owl:DatatypeProperty ;
    rdfs:label "uses musl" ;
    rdfs:domain apk:ApkPackage ;
    rdfs:range xsd:boolean ;
    IAO:0000115 "Whether the package is built against musl libc (true for Alpine, distinguishes from glibc-based distributions)." .

# Object Properties

apk:inRepository a owl:ObjectProperty ;
    rdfs:label "in repository" ;
    rdfs:domain apk:ApkPackage ;
    rdfs:range apk:ApkRepository ;
    IAO:0000115 "Associates a package with the Alpine repository (main/community/testing) it belongs to." .

apk:inBranch a owl:ObjectProperty ;
    rdfs:label "in branch" ;
    rdfs:domain apk:ApkRepository ;
    rdfs:range apk:ApkBranch ;
    IAO:0000115 "Associates a repository with its Alpine release branch." .

apk:builtFromAbuild a owl:ObjectProperty ;
    rdfs:label "built from APKBUILD" ;
    rdfs:domain apk:ApkPackage ;
    rdfs:range apk:AbuildScript ;
    IAO:0000115 "Associates a package with the APKBUILD script that produced it." .
